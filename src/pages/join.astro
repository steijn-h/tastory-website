---
import BaseLayout from '../layouts/BaseLayout.astro';

const { ref } = Astro.url.searchParams ? Object.fromEntries(Astro.url.searchParams) : {};
const appStoreUrl = 'https://apps.apple.com/nl/app/tastory/id6744042066';
---

<BaseLayout
  title="Uitnodiging voor Tastory"
  description="Je bent uitgenodigd om samen de leukste restaurants te ontdekken op Tastory."
>
  <div class="join-page">
    <div class="content">
      <div class="card reveal">
        <div class="logo">
          <img src="/images/tastory-logo.png" alt="Tastory" width="120" />
        </div>

        <div class="card-tag">Uitnodiging</div>

        <h1>Je bent uitgenodigd voor <em>Tastory</em></h1>

        <p class="cta-text">
          Ontdek samen de leukste restaurants. Download Tastory en voeg je vriend toe om elkaars favorieten te zien.
        </p>

        <a href={appStoreUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download Tastory op iOS
        </a>

        <p class="store-note">Binnenkort ook op Android</p>

        <div class="features">
          <div class="feature">
            <span class="feature-icon">🍽️</span>
            <span>Ontdek restaurants die bij jou passen</span>
          </div>
          <div class="feature">
            <span class="feature-icon">👥</span>
            <span>Zie wat vrienden lekker vinden</span>
          </div>
          <div class="feature">
            <span class="feature-icon">📸</span>
            <span>Deel je culinaire avonturen</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .join-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem 5rem;
    background: linear-gradient(135deg, var(--beige) 0%, #f0e4d4 100%);
  }

  .content {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .logo {
    margin-bottom: 1.5rem;
  }

  .logo img {
    height: 48px;
    width: auto;
  }

  .card-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(255, 142, 62, 0.1);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .card h1 {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .card h1 em {
    color: var(--orange);
    font-style: normal;
  }

  .cta-text {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .btn-primary:hover {
    background: var(--brown);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(255, 142, 62, 0.3);
  }

  .store-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-bottom: 2rem;
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
    border-top: 1px solid rgba(136, 101, 69, 0.1);
    padding-top: 1.5rem;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .feature-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }
</style>
