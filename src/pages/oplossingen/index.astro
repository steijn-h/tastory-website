---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Icon from '../../components/Icon.astro';
---

<BaseLayout
  title="Oplossingen — Tastory"
  description="Tastory biedt oplossingen voor zowel restaurants als gasten. Ontdek hoe wij jullie samenbrengen."
>
  <PageHero
    title="Oplossingen voor <em>restaurants</em> en <em>gasten</em>"
    description="Tastory brengt restaurants en gasten samen. Ontdek hoe onze app waarde creëert voor beide kanten."
  />

  <section class="solutions-overview">
    <div class="solutions-grid">
      <a href="/oplossingen/restaurants" class="solution-card reveal">
        <div class="solution-bg-icon"><Icon name="utensils" size={140} /></div>
        <h2>Voor restaurants</h2>
        <p>
          Via Tastory kunnen restaurants zich beter en eerlijker presenteren, terwijl gasten snel en eenvoudig restaurants ontdekken die echt bij ze passen.
        </p>
        <div class="solution-steps">
          <div class="solution-step">
            <span class="step-label">Find it</span>
            <span class="step-desc">Gasten ontdekken jouw restaurant via de Tastory app</span>
          </div>
          <div class="solution-step">
            <span class="step-label">Taste it</span>
            <span class="step-desc"
              >Gasten ervaren jouw gerechten en service in het restaurant</span
            >
          </div>
          <div class="solution-step">
            <span class="step-label">Share it</span>
            <span class="step-desc"
              >Gasten delen waardevolle feedback om de service te optimaliseren</span
            >
          </div>
        </div>
        <div class="solution-cta">
          <span>Bekijk oplossingen voor restaurants</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/oplossingen/gebruikers" class="solution-card reveal">
        <div class="solution-bg-icon"><Icon name="user" size={140} /></div>
        <h2>Voor gasten</h2>
        <p>
          Ontdek restaurants die écht bij jou passen. Zoek op de app, proef en deel je ervaring met je vrienden.
        </p>
        <div class="solution-steps">
          <div class="solution-step">
            <span class="step-label">Find it</span>
            <span class="step-desc">Ontdek hét restaurant dat bij je past</span>
          </div>
          <div class="solution-step">
            <span class="step-label">Taste it</span>
            <span class="step-desc"
              >Ga langs en proef de beste gerechten bij jouw gekozen restaurant</span
            >
          </div>
          <div class="solution-step">
            <span class="step-label">Share it</span>
            <span class="step-desc">Deel jouw ervaring en help anderen bij hun restaurantkeuze</span
            >
          </div>
        </div>
        <div class="solution-cta">
          <span>Bekijk oplossingen voor gasten</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .solutions-overview {
    max-width: 1400px;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .solution-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: 20px;
    padding: 3rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .solution-card:hover {
    border-color: rgba(255, 142, 62, 0.18);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .solution-bg-icon {
    position: absolute;
    bottom: 10px;
    right: 10px;
    color: var(--orange);
    opacity: 0.06;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .solution-card:hover .solution-bg-icon {
    opacity: 0.1;
  }

  .solution-card h2 {
    font-family: var(--serif);
    font-size: 1.6rem;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .solution-card > p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .solution-steps {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 2rem;
  }

  .solution-step {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1rem;
    border-left: 2px solid var(--orange);
  }

  .step-label {
    font-family: var(--serif);
    font-size: var(--text-lg);
    color: var(--orange);
    font-style: normal;
  }

  .step-desc {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .solution-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    align-self: flex-start;
    background: var(--orange);
    color: var(--white);
    font-size: var(--text-base);
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    transition: background 0.3s, transform 0.3s, gap 0.3s;
  }

  .solution-card:hover .solution-cta {
    background: var(--brown);
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .solutions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
