---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Icon from '../../components/Icon.astro';
import AppFunctions from '../../components/AppFunctions.astro';
import { appFunctions } from '../../data/home';
---

<BaseLayout
  title="Oplossingen voor gasten — Tastory"
  description="Ontdek restaurants die écht bij jou passen. Download de app, proef en deel jouw ervaringen."
>
  <PageHero
    title="Oplossingen voor <em>gasten</em>"
    description="Ontdek het restaurant dat perfect bij jouw smaak, stemming, budget en gezelschap past. Restaurants presenteren zich op de best mogelijke manier om jou te inspireren."
  />

  <section class="steps-section">
    <div class="reveal">
      <div class="section-tag">Hoe het werkt</div>
      <h2 class="section-title">In drie stappen naar de perfecte <em>restaurantervaring</em></h2>
    </div>
    <div class="steps-grid">
      <div class="step-card reveal">
        <div class="step-number">01</div>
        <h3>Find it</h3>
        <p>
          Download de app en ontdek het restaurant dat perfect bij jouw smaak, stemming, budget en
          gezelschap past. Restaurants presenteren zich op de best mogelijke manier om jou te
          inspireren.
        </p>
      </div>
      <div class="step-card reveal">
        <div class="step-number">02</div>
        <h3>Taste it</h3>
        <p>
          Ga langs en proef de beste gerechten bij jouw gekozen restaurant. Geniet van een ervaring
          die aansluit bij wat je had verwacht, dankzij de eerlijke en representatieve
          profielen.
        </p>
      </div>
      <div class="step-card reveal">
        <div class="step-number">03</div>
        <h3>Share it</h3>
        <p>
          Deel jouw ervaring met de community en help anderen bij het maken van hun volgende, nog
          betere restaurantkeuze. Tip: je kunt op onze app jouw eigen foodmap maken met alle
          bezochte restaurants!
        </p>
      </div>
    </div>
  </section>

  <section class="features-section">
    <div class="reveal">
      <div class="section-tag">Functies</div>
      <h2 class="section-title">De belangrijkste functies van <em>Tastory</em></h2>
    </div>
    <div class="user-features-grid">
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="search" size={100} /></div>
        <h3>Gericht zoeken</h3>
        <p>
          Filter op stemming, budget, keuken en gezelschap om precies het juiste restaurant te
          vinden.
        </p>
      </div>
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="film" size={100} /></div>
        <h3>Video-profielen</h3>
        <p>
          Bekijk sfeervolle video's van restaurants zodat je vooraf een goed beeld hebt van de
          beleving.
        </p>
      </div>
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="map" size={100} /></div>
        <h3>Persoonlijke foodmap</h3>
        <p>Maak je eigen foodmap met alle bezochte restaurants en deel deze met vrienden.</p>
      </div>
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="message-circle" size={100} /></div>
        <h3>Community reviews</h3>
        <p>
          Lees en schrijf eerlijke reviews die andere gasten helpen bij het maken van hun keuze.
        </p>
      </div>
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="smartphone" size={100} /></div>
        <h3>Delen met vrienden</h3>
        <p>
          Deel jouw favoriete restaurants en ervaringen eenvoudig via de app met vrienden en
          familie.
        </p>
      </div>
      <div class="user-feature reveal">
        <div class="user-feature-bg-icon"><Icon name="star" size={100} /></div>
        <h3>Betrouwbare matches</h3>
        <p>
          Onze matching met jouw profiel zorgt ervoor dat je verwachtingen beter overeenkomen met de werkelijke ervaring.
        </p>
      </div>
    </div>
  </section>

  <AppFunctions functions={appFunctions} />

  <section class="cta-users">
    <div class="cta-users-inner reveal">
      <h2 class="section-title">Klaar om te <em>ontdekken?</em></h2>
      <p>
        De Tastory app komt binnenkort beschikbaar op iOS en Android. Meld je aan voor de
        nieuwsbrief en wees de eerste die het hoort!
      </p>
      <form class="email-form" id="gebruiker-cta-form">
        <input
          type="email"
          id="gebruiker-cta-email"
          placeholder="Jouw e-mailadres"
          required
          aria-label="E-mailadres"
        />
        <button type="submit">Aanmelden</button>
      </form>
      <div class="form-feedback" id="gebruiker-cta-feedback"></div>
      <div class="cta-note">Geen spam. Altijd opzegbaar.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .steps-section {
    background: var(--beige);
    padding: 6rem 3rem;
    max-width: 100%;
  }

  .steps-section > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .step-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
  }

  .step-number {
    font-family: var(--serif);
    font-size: 3rem;
    color: var(--orange);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    font-family: var(--serif);
    font-size: var(--text-2xl);
    color: var(--text);
    font-style: normal;
    margin-bottom: 1rem;
  }

  .step-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Features */
  .features-section {
    background: var(--beige);
    padding: 6rem 3rem;
    max-width: 100%;
  }

  .features-section > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .user-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .user-feature {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: var(--radius-md);
    padding: 2rem;
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .user-feature:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .user-feature-bg-icon {
    position: absolute;
    bottom: 10px;
    right: 10px;
    color: var(--orange);
    opacity: 0.06;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .user-feature:hover .user-feature-bg-icon {
    opacity: 0.1;
  }

  .user-feature h3 {
    font-family: var(--serif);
    font-size: var(--text-xl);
    color: var(--text);
    margin-bottom: 0.6rem;
  }

  .user-feature p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* CTA */
  .cta-users {
    text-align: center;
    padding: 6rem 3rem;
    max-width: 100%;
    background: var(--beige);
    position: relative;
  }

  .cta-users::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 142, 62, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta-users-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-users-inner > p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .email-form {
    display: flex;
    max-width: 520px;
    margin: 0 auto;
    background: var(--white);
    border-radius: 100px;
    border: 1px solid rgba(136, 101, 69, 0.1);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(136, 101, 69, 0.06);
  }

  .email-form input {
    flex: 1;
    padding: 1rem 1.8rem;
    background: transparent;
    border: none;
    font-family: var(--sans);
    font-size: var(--text-base);
    color: var(--text);
    outline: none;
  }

  .email-form input::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .email-form button {
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 2rem;
    font-family: var(--sans);
    font-size: var(--text-base);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    border-radius: 0 100px 100px 0;
  }

  .email-form button:hover {
    background: var(--brown);
  }

  .form-feedback {
    font-size: 1rem;
    margin-top: 1rem;
    min-height: 1.5rem;
  }

  .form-feedback--success {
    color: #2e7d32;
  }

  .form-feedback--error {
    color: #c62828;
  }

  .cta-note {
    font-size: 1rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 1rem;
  }

  @media (max-width: 1024px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
    .user-features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .user-features-grid {
      grid-template-columns: 1fr;
    }
    .email-form {
      flex-direction: column;
      border-radius: 16px;
    }
    .email-form button {
      width: 100%;
      border-radius: 0 0 16px 16px;
    }
  }
</style>

<script>
  const form = document.getElementById('gebruiker-cta-form') as HTMLFormElement;
  const emailInput = document.getElementById('gebruiker-cta-email') as HTMLInputElement;
  const feedback = document.getElementById('gebruiker-cta-feedback') as HTMLDivElement;
  const submitBtn = form.querySelector('button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Verzenden...';

    try {
      const res = await fetch('https://formsubmit.co/ajax/Info@tastory.nl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          name: 'Gast aanmelding',
          email,
          message: 'Nieuwe gast aangemeld via de gasten oplossingen pagina.',
          _subject: 'Nieuwe gast aanmelding — Tastory',
          _captcha: 'false',
        }),
      });

      if (res.ok) {
        feedback.textContent = 'Bedankt voor je aanmelding! We laten het je weten zodra de app beschikbaar is.';
        feedback.className = 'form-feedback form-feedback--success';
        emailInput.value = '';
      } else {
        throw new Error('Submit failed');
      }
    } catch {
      feedback.textContent = 'Er ging iets mis. Probeer het later opnieuw.';
      feedback.className = 'form-feedback form-feedback--error';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Aanmelden';

    setTimeout(() => {
      feedback.textContent = '';
      feedback.className = 'form-feedback';
    }, 5000);
  });
</script>
