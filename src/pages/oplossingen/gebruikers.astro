---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AppFunctions from '../../components/AppFunctions.astro';
import { appFunctions } from '../../data/home';
---

<BaseLayout
  title="Oplossingen voor gasten — Tastory"
  description="Ontdek restaurants die écht bij jou passen. Download de app, proef en deel jouw ervaringen."
>
  <PageHero
    title="Oplossingen voor <em>gasten</em>"
    description="Ontdek het restaurant dat perfect bij jouw smaak, stemming, budget en gezelschap past. Restaurants presenteren zich op de best mogelijke manier om jou te inspireren."
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': ['WebPage', 'Service'],
      name: 'Oplossingen voor gasten — Tastory',
      url: 'https://www.tastory.nl/oplossingen/gebruikers',
      description:
        'Ontdek restaurants die écht bij jou passen. Download de Tastory app, proef en deel jouw ervaringen.',
      inLanguage: 'nl-NL',
      serviceType: 'Restaurantontdekking voor gasten',
      provider: {
        '@type': 'Organization',
        name: 'Tastory',
        url: 'https://www.tastory.nl',
      },
      areaServed: { '@type': 'Country', name: 'Nederland' },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.tastory.nl' },
          {
            '@type': 'ListItem',
            position: 2,
            name: 'Oplossingen',
            item: 'https://www.tastory.nl/oplossingen',
          },
          {
            '@type': 'ListItem',
            position: 3,
            name: 'Voor gasten',
            item: 'https://www.tastory.nl/oplossingen/gebruikers',
          },
        ],
      },
    })}
  />
  <section class="steps-section">
    <div class="reveal">
      <div class="section-tag">Hoe het werkt</div>
      <h2 class="section-title">In drie stappen naar de perfecte <em>restaurantervaring</em></h2>
    </div>
    <div class="steps-grid">
      <div class="step-card reveal">
        <div class="step-number">01</div>
        <h3>Find it</h3>
        <p>
          Open de app en zoek naar hét restaurant dat voldoet aan jouw huidige gezelschap, smaak,
          stemming en budget op basis van de juiste restaurantprofielen.
        </p>
      </div>
      <div class="step-card reveal">
        <div class="step-number">02</div>
        <h3>Taste it</h3>
        <p>
          Ga langs en proef de beste gerechten bij jouw gekozen restaurant. Geniet van een ervaring
          die aansluit bij wat je had verwacht, dankzij de eerlijke en representatieve profielen.
        </p>
      </div>
      <div class="step-card reveal">
        <div class="step-number">03</div>
        <h3>Share it</h3>
        <p>
          Deel jouw ervaring met de community en help anderen bij het maken van hun volgende, nog
          betere restaurantkeuze. Tip: je kunt op onze app jouw eigen foodmap maken met alle
          bezochte restaurants!
        </p>
      </div>
    </div>
  </section>

  <AppFunctions functions={appFunctions} />

  <section class="cta-users">
    <div class="cta-users-inner reveal">
      <h2 class="section-title">Klaar om te <em>ontdekken?</em></h2>
      <p>
        De Tastory app is nu live! Download hem gratis in de App Store en ontdek restaurants die
        écht bij jou passen.
      </p>
      <a
        href="https://apps.apple.com/nl/app/tastory/id6762256086"
        target="_blank"
        rel="noopener noreferrer"
        class="app-store-btn"
      >
        <img
          src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg"
          alt="Download on the App Store"
          width="156"
          height="52"
        />
      </a>
      <div class="cta-note">Gratis te downloaden. Beschikbaar op iOS.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .steps-section {
    background: var(--beige);
    padding: 6rem 3rem;
    max-width: 100%;
  }

  .steps-section > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .step-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
  }

  .step-number {
    font-family: var(--serif);
    font-size: 3rem;
    color: var(--orange);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    font-family: var(--serif);
    font-size: var(--text-2xl);
    color: var(--text);
    font-style: normal;
    margin-bottom: 1rem;
  }

  .step-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* CTA */
  .cta-users {
    text-align: center;
    padding: 6rem 3rem;
    max-width: 100%;
    background: var(--beige);
    position: relative;
  }

  .cta-users::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 142, 62, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta-users-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-users-inner > p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .app-store-btn {
    display: inline-block;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    transition: opacity 0.2s;
  }

  .app-store-btn:hover {
    opacity: 0.85;
  }

  .cta-note {
    font-size: 1rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 1rem;
  }

  @media (max-width: 1024px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
