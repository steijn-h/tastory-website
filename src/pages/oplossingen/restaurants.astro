---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---

<BaseLayout
  title="Oplossingen voor restaurants — Tastory"
  description="Ontdek hoe Tastory restaurants helpt met zichtbaarheid, imago en terugkerende gasten."
>
  <PageHero
    title="Ontdek Tastory, de app die met een representatief restaurantprofiel terugkerende gasten <em>realiseert</em>"
    description="Tastory helpt restaurants, gasten aan te trekken die oprecht jouw concept waarderen door middel van authentieke en representatieve restaurantprofielen."
  />

  <section>
    <div class="reveal">
      <div class="section-tag">Wat je bereikt</div>
      <h2 class="section-title">Vier doelen, &eacute;&eacute;n <em>app</em></h2>
    </div>
    <div class="goals-grid">
      <div class="goal-card reveal">
        <div class="goal-number">01</div>
        <h3>Betere zichtbaarheid</h3>
        <p>
          Word beter zichtbaar door actuele en professionele content op je restaurantprofiel.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">02</div>
        <h3>Representatief restaurantprofiel</h3>
        <p>
          Vertel het verhaal van jouw restaurant via short-form content. Gebruik je missie en visie
          om nieuwe gasten aan te trekken. Tastory zorgt dat de content wordt gemaakt.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">03</div>
        <h3>Terugkerende gasten</h3>
        <p>
          Gebruik inzichten en gastervaringen om je profiel representatiever te maken, zodat
          verwachtingen overeenkomen met de werkelijkheid.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">04</div>
        <h3>Betere reviews</h3>
        <p>
          Gebruik het Tastory-dashboard om verbeteringen door te voeren en ervaringen te verbeteren.
        </p>
      </div>
    </div>
  </section>

  <section class="pricing-section">
    <div class="reveal">
      <div class="section-tag">Pakketten</div>
      <h2 class="section-title">Kies het pakket dat bij jou <em>past</em></h2>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card reveal">
        <h3>Chefs Keuze</h3>
        <ul>
          <li>Kwalitatieve foto's en video's*</li>
          <li>Marketingplan</li>
          <li>Extra zichtbaarheid in de app</li>
          <li>Alles uit 3-gangen</li>
        </ul>
        <p class="footnote">* Kwalitatieve foto's en video worden geschoten door Tastory.</p>
      </div>
      <div class="pricing-card pricing-card--featured reveal">
        <div class="pricing-badge">Populair</div>
        <h3>3-Gangen Menu</h3>
        <ul>
          <li>Kwalitatieve foto's*</li>
          <li>Reservering klik-inzichten</li>
          <li>Alles uit Proeverij</li>
        </ul>
        <p class="footnote">* Kwalitatieve foto's worden geschoten door Tastory.</p>
      </div>
      <div class="pricing-card reveal">
        <h3>Proeverij</h3>
        <ul>
          <li>App-plaatsing</li>
          <li>Coming-soon portaal toegang</li>
          <li>Volledig profielbeheer in huisstijl</li>
          <li>Zelf content aanleveren*</li>
        </ul>
        <p class="footnote">* Jij levert jouw unieke foto's en video's aan volgens de richtlijnen en voorwaarden van Tastory. Zo houden wij de app objectief en creëren wij een uniforme standaard.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="reveal">
      <div class="section-tag">Professionele content</div>
      <h2 class="section-title">
        Short-form video's die jouw restaurant <em>tot leven brengen</em>
      </h2>
    </div>
    <div class="content-info reveal">
      <p>
        Tastory heeft als doel om de identiteit van jouw restaurant vast te leggen in professionele short-form content video's van +/- 45 seconden. Deze video's presenteren jouw restaurant op een authentieke en aantrekkelijke manier.
      </p>
    </div>
  </section>

  <section class="cta-restaurants">
    <div class="cta-restaurants-inner reveal">
      <h2 class="section-title">Klaar om <em>ontdekt te worden?</em></h2>
      <p>
        Meld jouw restaurant aan en wees er vroeg bij. We houden je op de hoogte van de lancering
        en nemen contact met je op!
      </p>
      <form class="email-form" id="restaurant-cta-form">
        <input
          type="email"
          id="restaurant-cta-email"
          placeholder="Jouw e-mailadres"
          required
          aria-label="E-mailadres"
        />
        <button type="submit">Aanmelden</button>
      </form>
      <div class="form-feedback" id="restaurant-cta-feedback"></div>
      <div class="cta-note">Geen spam. Altijd opzegbaar.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .goals-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .goal-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: var(--radius-md);
    padding: 2.5rem;
  }

  .goal-number {
    font-family: var(--serif);
    font-size: var(--text-3xl);
    color: var(--orange);
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .goal-card h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .goal-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Pricing */
  .pricing-section {
    background: var(--white);
    padding: 7rem 3rem;
    max-width: 100%;
  }

  .pricing-section > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-card {
    background: var(--beige);
    border: 1px solid rgba(136, 101, 69, 0.08);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
  }

  .pricing-card--featured {
    border-color: var(--orange);
    box-shadow: 0 10px 40px rgba(255, 142, 62, 0.12);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: var(--white);
    padding: 0.3rem 1.2rem;
    border-radius: 100px;
    font-size: var(--text-base);
    font-weight: 600;
  }

  .pricing-card h3 {
    font-family: var(--serif);
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .pricing-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pricing-card li {
    font-size: var(--text-base);
    color: var(--text);
    padding-left: 1.5rem;
    position: relative;
  }

  .pricing-card li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--orange);
    font-weight: 600;
  }

  .footnote {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
    line-height: 1.4;
  }

  .content-info {
    max-width: 700px;
    margin-top: 2rem;
  }

  .content-info p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  /* CTA */
  .cta-restaurants {
    padding: 8rem 3rem;
    text-align: center;
    background: var(--beige);
    max-width: 100%;
    position: relative;
  }

  .cta-restaurants::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 142, 62, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta-restaurants-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-restaurants-inner > p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .email-form {
    display: flex;
    max-width: 520px;
    margin: 0 auto;
    border: 1px solid rgba(136, 101, 69, 0.15);
    border-radius: 100px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 4px 20px rgba(136, 101, 69, 0.06);
  }

  .email-form input {
    flex: 1;
    padding: 1rem 1.8rem;
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    outline: none;
  }

  .email-form input::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .email-form button {
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 2rem;
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
    white-space: nowrap;
    border-radius: 0 100px 100px 0;
  }

  .email-form button:hover {
    background: var(--brown);
  }

  .form-feedback {
    font-size: 1rem;
    margin-top: 1rem;
    min-height: 1.5rem;
  }

  .form-feedback--success {
    color: #2e7d32;
  }

  .form-feedback--error {
    color: #c62828;
  }

  .cta-note {
    font-size: 1rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 1rem;
  }

  @media (max-width: 1024px) {
    .goals-grid {
      grid-template-columns: 1fr;
    }
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .email-form {
      flex-direction: column;
      border-radius: 16px;
    }
    .email-form button {
      width: 100%;
      border-radius: 0 0 16px 16px;
    }
  }
</style>

<script>
  const form = document.getElementById('restaurant-cta-form') as HTMLFormElement;
  const emailInput = document.getElementById('restaurant-cta-email') as HTMLInputElement;
  const feedback = document.getElementById('restaurant-cta-feedback') as HTMLDivElement;
  const submitBtn = form.querySelector('button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Verzenden...';

    try {
      const res = await fetch('https://formsubmit.co/ajax/Info@tastory.nl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          name: 'Restaurant aanmelding',
          email,
          message: 'Nieuw restaurant aangemeld via de restaurants oplossingen pagina.',
          _subject: 'Nieuwe restaurant aanmelding — Tastory',
          _captcha: 'false',
          _template: 'table',
        }),
      });

      if (res.ok) {
        feedback.textContent = 'Bedankt voor je aanmelding! We nemen snel contact met je op.';
        feedback.className = 'form-feedback form-feedback--success';
        emailInput.value = '';
      } else {
        throw new Error('Submit failed');
      }
    } catch {
      feedback.textContent = 'Er ging iets mis. Probeer het later opnieuw.';
      feedback.className = 'form-feedback form-feedback--error';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Aanmelden';

    setTimeout(() => {
      feedback.textContent = '';
      feedback.className = 'form-feedback';
    }, 5000);
  });
</script>
