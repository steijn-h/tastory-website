---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Icon from '../../components/Icon.astro';
---

<BaseLayout
  title="Oplossingen voor restaurants — Tastory"
  description="Ontdek hoe Tastory restaurants helpt met zichtbaarheid, imago en terugkerende gasten."
>
  <PageHero
    title="Tastory, de app die met een representatief restaurantprofiel terugkerende gasten <em>realiseert</em>"
    description="Via Tastory kunnen restaurants zich beter en eerlijker presenteren, terwijl gasten snel en eenvoudig restaurants ontdekken die echt bij ze passen."
  />

  <section class="goals-section">
    <div class="reveal">
      <div class="section-tag">Wat je bereikt</div>
      <h2 class="section-title">Vier doelen, &eacute;&eacute;n <em>app</em></h2>
    </div>
    <div class="goals-grid">
      <div class="goal-card reveal">
        <div class="goal-number">01</div>
        <h3>Betere zichtbaarheid</h3>
        <p>
          Bereik gasten die actief op zoek zijn naar een restaurant zoals de jouwe. Door een authentiek restaurantprofiel met acutele, professionele content val je op, precies op het moment dat telt.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">02</div>
        <h3>Gasten die écht bij jou passen</h3>
        <p>
          Vertel het verhaal van jouw restaurant via authentieke content. Zo trek je gasten aan die jouw concept waarderen en niet alleen op zoek zijn naar de goedkoopste optie.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">03</div>
        <h3>Terugkerende gasten</h3>
        <p>
          Gasten die precies weten wat ze kunnen verwachten en komen terug. Tastory zorgt voor loyale gasten door de verwachting van een restaurant aan te laten sluiten op realiteit.
        </p>
      </div>
      <div class="goal-card reveal">
        <div class="goal-number">04</div>
        <h3>Betrouwbare reviews</h3>
        <p>
          Elke review op Tastory wordt gevalideerd. Zo weet jij zeker dat de feedback die je ontvangt eerlijk is en kun je er ook daadwerkelijk iets mee.
        </p>
      </div>
    </div>
  </section>

  <section class="pricing-section">
    <div class="reveal">
      <div class="section-tag">Gerechten</div>
      <h2 class="section-title">Kies de gerechten die bij jou <em>passen</em></h2>
      <p class="pricing-intro">Wij hebben de beste ingrediënten voor jouw succes al klaarstaan. Hieronder een greep uit wat Tastory voor jouw restaurant kan betekenen.</p>
    </div>
    <div class="dishes-list">
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Gepersonaliseerd profiel</h3>
          <p>Een authentiek restaurantprofiel dat jouw concept, sfeer en keuken laat zien op de manier die bij jou past.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Professionele video</h3>
          <p>Kwalitatieve video die de sfeer en het karakter van jouw restaurant tot leven brengt voor potentiële gasten.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Professionele foto's</h3>
          <p>Stijlvolle foto's van jouw gerechten, interieur en team die bezoekers direct het gevoel geven van jouw restaurant.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Reserveringsbevestiging</h3>
          <p>Automatische bevestiging zodat gasten met een goed gevoel de deur uitlopen en weten wat ze kunnen verwachten.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Loyaliteitsprogramma</h3>
          <p>Een uniek programma dat vaste gasten beloont en terugkeer stimuleert op een manier die bij jouw formule past.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Webpagina op Google</h3>
          <p>Vergroot je vindbaarheid met een eigen webpagina die hoog scoort in Google en nieuwe gasten naar jou toe trekt.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Inzicht in populariteit</h3>
          <p>Inzicht in hoe jouw restaurant presteert in de buurt, zodat je beter kunt inspelen op de wensen van jouw doelgroep.</p>
        </div>
      </div>
      <div class="dish-row reveal">
        <div class="dish-icon"><Icon name="check" size={20} /></div>
        <div class="dish-content">
          <h3>Links naar website & socials</h3>
          <p>Directe links vanuit jouw Tastory-profiel naar jouw eigen website en sociale media kanalen voor maximale zichtbaarheid.</p>
        </div>
      </div>
    </div>
    <p class="pricing-footer reveal">Dit is een selectie van de beschikbare opties. Na contact bespreken we alle mogelijkheden die bij jouw restaurant passen.</p>
  </section>

  <section class="how-it-works">
    <div class="reveal">
      <div class="section-tag">Zo werkt het</div>
      <h2 class="section-title">In drie stappen <em>live</em></h2>
    </div>
    <div class="steps-grid">
      <div class="step reveal">
        <div class="step-number">01</div>
        <h3>Aanmelden</h3>
        <p>Meld je restaurant aan en kies de gerechten die het beste bij jou passen. We nemen snel contact met je op.</p>
      </div>
      <div class="step reveal">
        <div class="step-number">02</div>
        <h3>Content creëren</h3>
        <p>We gaan met jou in gesprek om jouw restaurant zo persoonlijk en goed mogelijk te kunnen laten zien. Daarna schiet Tastory professionele foto's en video's die het karakter van jouw restaurant laten zien.</p>
      </div>
      <div class="step reveal">
        <div class="step-number">03</div>
        <h3>Ontdekt worden</h3>
        <p>Jouw restaurant verschijnt in de Tastory app en bereikt gasten die écht bij jou passen.</p>
      </div>
    </div>
  </section>

  <section class="cta-restaurants">
    <div class="cta-restaurants-inner reveal">
      <h2 class="section-title">Klaar om <em>ontdekt te worden?</em></h2>
      <p>
        Meld jouw restaurant aan en wees er vroeg bij. We houden je op de hoogte van de lancering
        en nemen contact met je op!
      </p>
      <form class="email-form" id="restaurant-cta-form">
        <input
          type="email"
          id="restaurant-cta-email"
          placeholder="Jouw e-mailadres"
          required
          aria-label="E-mailadres"
        />
        <button type="submit">Aanmelden</button>
      </form>
      <div class="form-feedback" id="restaurant-cta-feedback"></div>
      <div class="cta-note">Geen spam. Altijd opzegbaar.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .goals-section {
    max-width: 100%;
  }

  .goals-section > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .goals-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .goal-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.06);
    border-radius: var(--radius-md);
    padding: 2.5rem;
  }

  .goal-number {
    font-family: var(--serif);
    font-size: var(--text-3xl);
    color: var(--orange);
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .goal-card h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .goal-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Pricing / Gerechten */
  .pricing-section {
    background: var(--beige);
    padding: 6rem 3rem;
    max-width: 100%;
  }

  .pricing-section > .reveal {
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .pricing-intro {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .dishes-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-top: 3.5rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .dish-row {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(136, 101, 69, 0.08);
    transition: background 0.2s ease;
  }

  .dish-row:nth-child(odd) {
    border-right: 1px solid rgba(136, 101, 69, 0.08);
  }

  .dish-row:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .dish-row:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .dish-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    background: rgba(255, 142, 62, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--orange);
    margin-top: 0.1rem;
  }

  .dish-icon :global(.icon) {
    stroke-width: 3;
  }

  .dish-content h3 {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 0.3rem;
    line-height: 1.35;
  }

  .dish-content p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .pricing-footer {
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0.75;
  }

  /* How it works */
  .how-it-works {
    background: var(--beige);
    max-width: 100%;
    padding: 6rem 3rem;
  }

  .how-it-works > .reveal {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .step {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.08);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    position: relative;
  }

  .step-number {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--orange);
    opacity: 0.18;
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .step h3 {
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .step p {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--text-muted);
  }

  /* CTA */
  .cta-restaurants {
    padding: 6rem 3rem;
    text-align: center;
    background: var(--beige);
    max-width: 100%;
    position: relative;
  }

  .cta-restaurants::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 142, 62, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta-restaurants-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-restaurants-inner > p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .email-form {
    display: flex;
    max-width: 520px;
    margin: 0 auto;
    border: 1px solid rgba(136, 101, 69, 0.15);
    border-radius: 100px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 4px 20px rgba(136, 101, 69, 0.06);
  }

  .email-form input {
    flex: 1;
    padding: 1rem 1.8rem;
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    outline: none;
  }

  .email-form input::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .email-form button {
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 2rem;
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
    white-space: nowrap;
    border-radius: 0 100px 100px 0;
  }

  .email-form button:hover {
    background: var(--brown);
  }

  .form-feedback {
    font-size: 1rem;
    margin-top: 1rem;
    min-height: 1.5rem;
  }

  .form-feedback--success {
    color: #2e7d32;
  }

  .form-feedback--error {
    color: #c62828;
  }

  .cta-note {
    font-size: 1rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 1rem;
  }

  @media (max-width: 1024px) {
    .goals-grid {
      grid-template-columns: 1fr;
    }
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .how-it-works {
      padding: 4rem 1.5rem;
    }
    .pricing-section {
      padding: 4rem 1.5rem;
    }
    .dishes-list {
      grid-template-columns: 1fr;
    }
    .dish-row:nth-child(odd) {
      border-right: none;
    }
    .dish-row:nth-last-child(-n+2) {
      border-bottom: 1px solid rgba(136, 101, 69, 0.08);
    }
    .dish-row:last-child {
      border-bottom: none;
    }
  }

  @media (max-width: 640px) {
    .email-form {
      flex-direction: column;
      border-radius: 16px;
    }
    .email-form button {
      width: 100%;
      border-radius: 0 0 16px 16px;
    }
  }
</style>

<script>
  // Form
  const form = document.getElementById('restaurant-cta-form') as HTMLFormElement;
  const emailInput = document.getElementById('restaurant-cta-email') as HTMLInputElement;
  const feedback = document.getElementById('restaurant-cta-feedback') as HTMLDivElement;
  const submitBtn = form.querySelector('button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Verzenden...';

    try {
      const res = await fetch('https://formsubmit.co/ajax/Info@tastory.nl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          name: 'Restaurant aanmelding',
          email,
          message: 'Nieuw restaurant aangemeld via de restaurants oplossingen pagina.',
          _subject: 'Nieuwe restaurant aanmelding — Tastory',
          _captcha: 'false',
          _template: 'table',
        }),
      });

      if (res.ok) {
        feedback.textContent = 'Bedankt voor je aanmelding! We nemen snel contact met je op.';
        feedback.className = 'form-feedback form-feedback--success';
        emailInput.value = '';
      } else {
        throw new Error('Submit failed');
      }
    } catch {
      feedback.textContent = 'Er ging iets mis. Probeer het later opnieuw.';
      feedback.className = 'form-feedback form-feedback--error';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Aanmelden';

    setTimeout(() => {
      feedback.textContent = '';
      feedback.className = 'form-feedback';
    }, 5000);
  });
</script>
