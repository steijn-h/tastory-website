---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Portfolio — Tastory"
  description="Bekijk ons werk: foto's en video's die wij voor restaurants hebben gemaakt."
>
  <PageHero
    title="Ons <em>werk</em> in beeld"
    description="Kwalitatieve content die restaurants het beste laat zien. Hieronder vind je een voorbeeldvideo die wat langer duurt om de verschillende mogelijkheden te laten zien."
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Portfolio — Tastory',
      url: 'https://www.tastory.nl/portfolio',
      description:
        'Bekijk ons werk: professionele foto\'s en video\'s die Tastory voor restaurants heeft gemaakt. Kwalitatieve content die restaurants het beste laat zien.',
      inLanguage: 'nl-NL',
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.tastory.nl' },
          {
            '@type': 'ListItem',
            position: 2,
            name: 'Portfolio',
            item: 'https://www.tastory.nl/portfolio',
          },
        ],
      },
      publisher: {
        '@type': 'Organization',
        name: 'Tastory',
        url: 'https://www.tastory.nl',
        logo: 'https://www.tastory.nl/tastory-logo.png',
      },
    })}
  />
  <section class="portfolio-section">
    <div class="container">
      <div class="section-label reveal">Video</div>

      <div class="video-block reveal">
        <div class="video-wrapper">
          <iframe
            src="https://www.youtube.com/embed/jbv-DdTNohI?vq=hd1080&rel=0"
            title="Tastory — restaurantvideo"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .portfolio-section {
    padding: 6rem 3rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-label {
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .video-block {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--brown);
    box-shadow: var(--shadow-xl);
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-caption {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
  }

  @media (max-width: 768px) {
    .portfolio-section {
      padding: 4rem 1.5rem 6rem;
    }
  }
</style>
