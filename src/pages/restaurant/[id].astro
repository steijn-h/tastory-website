---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;

let restaurant: {
  id: string;
  name: string;
  photo_url: string | null;
  background_url: string | null;
  city: string | null;
  cuisine: string | null;
  vibe: string | null;
  price_level: number | null;
  weighted_score: number | null;
  description: string | null;
  website: string | null;
  address: string | null;
} | null = null;

try {
  const res = await fetch(`https://vyqpdtjpocndgdqylzeo.supabase.co/functions/v1/Restaurant-pagina?id=${id}`);
  if (res.ok) {
    const data = await res.json();
    restaurant = data ?? null;
  }
} catch {
  restaurant = null;
}

const priceLabel = (level: number | null) => '€'.repeat(Math.max(1, Math.min(level ?? 1, 4)));

const title = restaurant
  ? `${restaurant.name} in ${restaurant.city} — Tastory`
  : 'Restaurant — Tastory';
const description = restaurant?.description
  ?? (restaurant ? `Bekijk ${restaurant.name} op Tastory.` : 'Bekijk dit restaurant op Tastory.');
const ogImage = restaurant?.photo_url ?? 'https://tastory.nl/og-image.png';
const appStoreUrl = 'https://apps.apple.com/nl/app/tastory/id6744042066';
const deepLinkUrl = `tastory://restaurant/${id}`;
---

<BaseLayout ogImage={ogImage} title={title} description={description}>
  <div class="restaurant-page">
    <div class="content">
      <div class="card reveal">
        {restaurant ? (
          <>
            {restaurant.photo_url && (
              <div class="photo-wrap">
                <img src={restaurant.photo_url} alt={restaurant.name} class="photo" />
              </div>
            )}
            <div class="info">
              <h1 class="name">{restaurant.name}</h1>
              <p class="city">{restaurant.city}</p>
              <div class="meta">
                {restaurant.cuisine && <span class="tag">{restaurant.cuisine}</span>}
                {restaurant.vibe && <span class="tag">{restaurant.vibe}</span>}
                {restaurant.price_level && <span class="tag">{priceLabel(restaurant.price_level)}</span>}
                {restaurant.weighted_score && (
                  <span class="tag score">★ {Number(restaurant.weighted_score).toFixed(1)}</span>
                )}
              </div>
              {restaurant.description && (
                <p class="description">{restaurant.description}</p>
              )}
              {restaurant.address && (
                <p class="address">📍 {restaurant.address}</p>
              )}
            </div>
          </>
        ) : (
          <h1>Restaurant bekijken</h1>
        )}

        <a href={deepLinkUrl} class="btn-primary" id="open-app-btn">
          Open in Tastory
        </a>

        <div class="divider">
          <span>Heb je Tastory nog niet?</span>
        </div>

        <a href={appStoreUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download Tastory
        </a>

        <p class="store-note">Beschikbaar op iOS · Binnenkort op Android</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .restaurant-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 6rem 1.5rem 4rem;
    background-color: #F5EBDD;
  }

  .content {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }

  .card {
    background: #ffffff;
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .photo-wrap {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    aspect-ratio: 4/3;
    max-height: 280px;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info {
    margin-bottom: 1.5rem;
  }

  .name {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
    font-family: var(--serif);
  }

  .city {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--brown);
    background: rgba(136, 101, 69, 0.1);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
  }

  .tag.score {
    color: var(--orange);
    background: rgba(255, 142, 62, 0.1);
    font-weight: 600;
  }

  .description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .address {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--orange);
    color: #ffffff;
    border: none;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 1.25rem;
  }

  .btn-primary:hover {
    background: var(--brown);
    transform: translateY(-1px);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(136, 101, 69, 0.15);
  }

  .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #F5EBDD;
    color: var(--text);
    border: 1px solid rgba(136, 101, 69, 0.2);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .btn-secondary:hover {
    background: rgba(136, 101, 69, 0.1);
    transform: translateY(-1px);
  }

  .store-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.6;
  }
</style>

<script>
  const appBtn = document.getElementById('open-app-btn');
  if (appBtn) {
    appBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const deepLink = appBtn.getAttribute('href');
      if (!deepLink) return;
      window.location.href = deepLink;
    });
  }
</script>
