---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const { slug } = Astro.params;

let restaurant: {
  id: string;
  name: string;
  photo_url: string | null;
  background_url: string | null;
  city: string | null;
  cuisine: string | null;
  vibe: string | null;
  price_level: number | null;
  weighted_score: number | null;
  description: string | null;
  website: string | null;
  address: string | null;
  slug: string | null;
  opening_hours: string | null;
  is_premium: boolean;
  video_url: string | null;
} | null = null;

try {
  const res = await fetch(`https://vyqpdtjpocndgdqylzeo.supabase.co/functions/v1/Restaurant-pagina?slug=${slug}`);
  if (res.ok) {
    const data = await res.json();
    restaurant = data ?? null;
  }
} catch {
  restaurant = null;
}

const priceLabel = (level: number | null) => '€'.repeat(Math.max(1, Math.min(level ?? 1, 4)));
const allPhotos: string[] = restaurant?.photo_url
  ? restaurant.photo_url.split(',').map(s => s.trim()).filter(Boolean)
  : [];
const videoUrl = restaurant?.video_url ?? null;
const backgroundUrl = restaurant?.background_url ?? null;
const heroPhoto = allPhotos[0] ?? null;
const visiblePhotos = allPhotos.slice(0, 3);
const extraCount = allPhotos.length - 3;

const appStoreUrl = 'https://apps.apple.com/nl/app/tastory/id6744042066';
const deepLinkUrl = `tastory://restaurant/${restaurant?.id ?? ''}`;
const mapsUrl = restaurant?.address
  ? `https://maps.google.com/?q=${encodeURIComponent(restaurant.address + ' ' + (restaurant.city ?? ''))}`
  : null;

const title = restaurant
  ? `${restaurant.name} in ${restaurant.city} — Tastory`
  : 'Restaurant — Tastory';
const description = restaurant?.description
  ?? (restaurant ? `Bekijk ${restaurant.name} op Tastory.` : 'Bekijk dit restaurant op Tastory.');
const ogImage = heroPhoto ?? 'https://tastory.nl/og-image.png';
const keywords = restaurant
  ? [restaurant.name!, restaurant.city!, restaurant.cuisine!, restaurant.vibe!, 'restaurant', 'Tastory']
      .filter(Boolean) as string[]
  : [];

const isPremium = restaurant?.is_premium === true;
---

<BaseLayout ogImage={ogImage} title={title} description={description} keywords={keywords}>
  {isPremium ? (

    <div class="premium-page restaurant-premium-page" style={backgroundUrl ? `background-image: url('${backgroundUrl}')` : ''}>
      <div class="page-inner">

        <!-- Hero: video of eerste foto -->
        <div class="hero reveal">
          {videoUrl ? (
            <>
              <video id="hero-video" src={videoUrl} class="hero-media" loop playsinline preload="metadata" />
              <button class="play-btn" id="play-btn" aria-label="Speel video af">
                <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </>
          ) : heroPhoto ? (
            <img src={heroPhoto} alt={restaurant!.name} class="hero-media" />
          ) : (
            <div class="hero-placeholder" />
          )}
          <div class="hero-overlay" />
          <div class="hero-content">
            <h1 class="hero-name">{restaurant!.name}</h1>
            {mapsUrl ? (
              <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="hero-city hero-city-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                {restaurant!.city}{restaurant!.address && <span class="hero-address"> · {restaurant!.address}</span>}
              </a>
            ) : (
              <p class="hero-city">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                {restaurant!.city}
              </p>
            )}
            <div class="hero-tags">
              {restaurant!.cuisine && <span class="hero-tag">{restaurant!.cuisine}</span>}
              {restaurant!.vibe && <span class="hero-tag">{restaurant!.vibe}</span>}
              {restaurant!.price_level && <span class="hero-tag">{priceLabel(restaurant!.price_level)}</span>}
              {restaurant!.weighted_score && (
                <span class="hero-tag score">★ {Number(restaurant!.weighted_score).toFixed(1)}</span>
              )}
            </div>
          </div>
        </div>

        <!-- CTA: 3 vakken (desktop), verborgen op mobiel -->
        <div class="cta-grid reveal">
          {mapsUrl ? (
            <a href={mapsUrl} class="cta-block cta-info" target="_blank" rel="noopener noreferrer">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span class="cta-block-label">{restaurant!.address}</span>
              <span class="cta-block-sub">Bekijk op kaart</span>
            </a>
          ) : (
            <div class="cta-block cta-info">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span class="cta-block-label">{restaurant!.city}</span>
              <span class="cta-block-sub">Locatie</span>
            </div>
          )}
          <a href={appStoreUrl} class="cta-block cta-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="cta-block-label">Download Tastory</span>
            <span class="cta-block-sub">Gratis op iOS</span>
          </a>
          <a href={deepLinkUrl} class="cta-block cta-primary" id="open-app-btn">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="cta-block-label">Open in Tastory</span>
            <span class="cta-block-sub">Bekijk video's & reviews</span>
          </a>
        </div>

        <!-- Beschrijving -->
        {restaurant!.description && (
          <section class="content-section reveal">
            <h2 class="section-title">Over dit restaurant</h2>
            <p class="description">{restaurant!.description}</p>
          </section>
        )}

        <!-- Foto's -->
        {allPhotos.length > 0 && (
          <section class="content-section reveal">
            <h2 class="section-title">Foto's</h2>
            <div class="gallery">
              {visiblePhotos.map((src, i) => (
                <div class="gallery-item" data-index={i}>
                  <img src={src} alt={`${restaurant!.name} foto ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
                </div>
              ))}
              {extraCount > 0 && (
                <button class="gallery-more" id="gallery-more-btn">
                  <span>+{extraCount}</span>
                  <span class="gallery-more-sub">meer foto's</span>
                </button>
              )}
            </div>
            <!-- Verborgen extra foto's -->
            {extraCount > 0 && (
              <div class="gallery-extra" id="gallery-extra" style="display:none">
                {allPhotos.slice(3).map((src, i) => (
                  <div class="gallery-item">
                    <img src={src} alt={`${restaurant!.name} foto ${i + 4}`} loading="lazy" />
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        <!-- Lightbox -->
        <div class="lightbox" id="lightbox" style="display:none">
          <button class="lightbox-close" id="lightbox-close">✕</button>
          <button class="lightbox-prev" id="lightbox-prev">‹</button>
          <button class="lightbox-next" id="lightbox-next">›</button>
          <img class="lightbox-img" id="lightbox-img" src="" alt="" />
          <p class="lightbox-counter" id="lightbox-counter"></p>
        </div>

        <!-- Openingstijden -->
        {restaurant!.opening_hours && (
          <section class="content-section reveal">
            <h2 class="section-title">Openingstijden</h2>
            <p class="hours-text">{restaurant!.opening_hours}</p>
          </section>
        )}

      </div>

      <!-- Mobiele sticky CTA balk -->
      <div class="mobile-cta">
        <a href={deepLinkUrl} class="mobile-cta-btn" id="mobile-app-btn">Open in Tastory</a>
        <a href={appStoreUrl} class="mobile-cta-download" target="_blank" rel="noopener noreferrer">Download</a>
      </div>

    </div>

  ) : (

    <!-- STANDAARD PAGINA -->
    <div class="restaurant-page">
      <div class="content">
        <div class="card reveal">
          {restaurant ? (
            <>
              {allPhotos[0] && (
                <div class="photo-wrap">
                  <img src={allPhotos[0]} alt={restaurant.name} class="photo" />
                </div>
              )}
              <div class="info">
                <h1 class="name">{restaurant.name}</h1>
                <p class="city">{restaurant.city}</p>
                <div class="meta">
                  {restaurant.cuisine && <span class="tag">{restaurant.cuisine}</span>}
                  {restaurant.vibe && <span class="tag">{restaurant.vibe}</span>}
                  {restaurant.price_level && <span class="tag">{priceLabel(restaurant.price_level)}</span>}
                  {restaurant.weighted_score && (
                    <span class="tag score">★ {Number(restaurant.weighted_score).toFixed(1)}</span>
                  )}
                </div>
                {restaurant.description && <p class="description">{restaurant.description}</p>}
                {restaurant.address && <p class="address">📍 {restaurant.address}</p>}
              </div>
            </>
          ) : (
            <h1>Restaurant bekijken</h1>
          )}
          <a href={deepLinkUrl} class="btn-primary" id="open-app-btn">Open in Tastory</a>
          <div class="divider"><span>Heb je Tastory nog niet?</span></div>
          <a href={appStoreUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            Download Tastory
          </a>
          <p class="store-note">Beschikbaar op iOS · Binnenkort op Android</p>
        </div>
      </div>
    </div>

  )}
</BaseLayout>

<style is:global>
  body.page-restaurant footer {
    background: var(--beige-dark) !important;
    color: var(--text-muted) !important;
  }

  body.page-restaurant footer a,
  body.page-restaurant footer h4,
  body.page-restaurant footer .footer-brand {
    color: var(--text) !important;
    opacity: 1 !important;
  }

  body.page-restaurant footer .footer-brand-sub {
    color: var(--text-muted) !important;
    opacity: 1 !important;
  }
</style>

<style>
  /* ── PREMIUM PAGE ─────────────────────────────────────── */

  .premium-page {
    min-height: 100vh;
    background-color: var(--beige);
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    padding-bottom: 5rem;
  }

  .page-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-lg) var(--space-2xl);
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    margin-top: 90px;
    min-height: 400px;
    max-height: 620px;
    overflow: hidden;
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    margin-bottom: var(--space-xl);
    box-shadow: var(--shadow-xl);
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-placeholder {
    width: 100%;
    height: 100%;
    background: var(--brown);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.65) 100%);
    pointer-events: none;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2xl);
    color: #fff;
  }

  .hero-name {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 0.5rem;
  }

  .hero-city {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-sm);
    opacity: 0.85;
    margin-bottom: var(--space-md);
  }

  .hero-address { opacity: 0.7; }

  .hero-city-link {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .hero-city-link:hover { opacity: 0.75; }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .hero-tag {
    font-size: var(--text-xs);
    font-weight: 500;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    color: #fff;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .hero-tag.score {
    background: rgba(255,142,62,0.75);
    border-color: transparent;
  }

  /* Play knop */
  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(8px);
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    z-index: 2;
  }

  .play-btn:hover {
    background: rgba(255,255,255,0.35);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .play-btn.hidden { display: none; }

  /* CTA grid: 3 vakken gecentreerd */
  .cta-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 260px));
    gap: 0.75rem;
    margin-bottom: var(--space-xl);
    justify-content: center;
  }

  .cta-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: var(--space-lg) var(--space-md);
    border-radius: var(--radius-md);
    text-decoration: none;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
    border: none;
  }

  .cta-block:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }

  .cta-primary {
    background: var(--orange);
    color: #fff;
  }

  .cta-secondary {
    background: var(--brown);
    color: #fff;
  }

  .cta-info {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    color: var(--text);
  }

  .cta-block-label {
    font-family: var(--sans);
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: 1.2;
  }

  .cta-block-sub {
    font-size: var(--text-xs);
    opacity: 0.75;
  }

  /* Content secties */
  .content-section {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
    box-shadow: var(--shadow-sm);
  }

  .section-title {
    font-family: var(--serif);
    font-size: var(--text-xl);
    color: var(--text);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(136,101,69,0.15);
  }

  .description {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.8;
  }

  .hours-text {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.8;
    white-space: pre-line;
  }

  /* Fotogalerij */
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .gallery-item {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .gallery-item:hover img { transform: scale(1.05); }

  .gallery-more {
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(136,101,69,0.12);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.2s;
    gap: 0.25rem;
  }

  .gallery-more:hover { background: rgba(136,101,69,0.2); }

  .gallery-more span:first-child {
    font-family: var(--serif);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--brown);
  }

  .gallery-more-sub {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .gallery-extra {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(255,255,255,0.15);
    border: none;
    color: #fff;
    font-size: 1.25rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-close:hover { background: rgba(255,255,255,0.25); }

  .lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: none;
    color: #fff;
    font-size: 2rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-prev { left: 1.25rem; }
  .lightbox-next { right: 1.25rem; }
  .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255,255,255,0.25); }

  .lightbox-counter {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.7);
    font-size: var(--text-sm);
  }

  /* Mobiele sticky CTA */
  .mobile-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem 1rem;
    gap: 0.6rem;
    z-index: 100;
    align-items: center;
  }

  .mobile-cta-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--orange);
    color: #fff;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s;
    box-shadow: 0 4px 16px rgba(255,142,62,0.4);
  }

