    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .btn-secondary:hover { background: var(--brown-dark); transform: translateY(-1px); }

  .store-note { font-size: 0.8rem; color: var(--text-muted); opacity: 0.6; }
</style>

<script>
  // Zet body class voor footer styling
  document.body.classList.add('page-restaurant');

  // Deep link handlers
  document.getElementById('open-app-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    const link = (e.currentTarget as HTMLAnchorElement).href;
    if (link) window.location.href = link;
  });

  document.getElementById('mobile-app-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    const link = (e.currentTarget as HTMLAnchorElement).href;
    if (link) window.location.href = link;
  });

  // Video play knop
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const playBtn = document.getElementById('play-btn');
  if (video && playBtn) {
    playBtn.addEventListener('click', () => { video.play(); playBtn.classList.add('hidden'); });
    video.addEventListener('pause', () => playBtn.classList.remove('hidden'));
  }

  // Foto's uitklappen
  const moreBtn = document.getElementById('gallery-more-btn');
  const extraGallery = document.getElementById('gallery-extra');
  if (moreBtn && extraGallery) {
    moreBtn.addEventListener('click', () => {
      extraGallery.style.display = 'grid';
      moreBtn.style.display = 'none';
    });
  }

  // Lightbox
  const allImgs: string[] = Array.from(document.querySelectorAll('.gallery-item img'))
    .map(img => (img as HTMLImageElement).src);
  let current = 0;

  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCounter = document.getElementById('lightbox-counter');

  function openLightbox(index: number) {
    current = index;
    lbImg.src = allImgs[current];
    if (lbCounter) lbCounter.textContent = `${current + 1} / ${allImgs.length}`;
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.gallery-item').forEach((item, i) => {
    item.addEventListener('click', () => openLightbox(i));
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', () => {
    openLightbox((current - 1 + allImgs.length) % allImgs.length);
  });
  document.getElementById('lightbox-next')?.addEventListener('click', () => {
    openLightbox((current + 1) % allImgs.length);
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox.style.display === 'flex') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') openLightbox((current - 1 + allImgs.length) % allImgs.length);
      if (e.key === 'ArrowRight') openLightbox((current + 1) % allImgs.length);
    }
  });
</script>
