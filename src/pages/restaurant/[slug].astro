---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const { slug } = Astro.params;

let restaurant: {
  id: string;
  name: string;
  photo_url: string | null;
  background_url: string | null;
  city: string | null;
  cuisine: string | null;
  vibe: string | null;
  price_level: number | null;
  weighted_score: number | null;
  description: string | null;
  website: string | null;
  address: string | null;
  slug: string | null;
  opening_hours: string | null;
  is_premium: boolean;
  video_url: string | null;
} | null = null;

try {
  const res = await fetch(`https://vyqpdtjpocndgdqylzeo.supabase.co/functions/v1/Restaurant-pagina?slug=${slug}`);
  if (res.ok) {
    const data = await res.json();
    restaurant = data ?? null;
  }
} catch {
  restaurant = null;
}

const priceLabel = (level: number | null) => '€'.repeat(Math.max(1, Math.min(level ?? 1, 4)));
const allPhotos: string[] = restaurant?.photo_url
  ? restaurant.photo_url.split(',').map(s => s.trim()).filter(Boolean)
  : [];
const videoUrl = restaurant?.video_url ?? null;
const heroMedia = videoUrl ?? allPhotos[0] ?? null;

const appStoreUrl = 'https://apps.apple.com/nl/app/tastory/id6744042066';
const deepLinkUrl = `tastory://restaurant/${restaurant?.id ?? ''}`;

const title = restaurant
  ? `${restaurant.name} in ${restaurant.city} — Tastory`
  : 'Restaurant — Tastory';
const description = restaurant?.description
  ?? (restaurant ? `Bekijk ${restaurant.name} op Tastory.` : 'Bekijk dit restaurant op Tastory.');
const ogImage = allPhotos[0] ?? 'https://tastory.nl/og-image.png';
const keywords = restaurant
  ? [restaurant.name!, restaurant.city!, restaurant.cuisine!, restaurant.vibe!, 'restaurant', 'Tastory']
      .filter(Boolean) as string[]
  : [];

const isPremium = restaurant?.is_premium === true;
---

<BaseLayout ogImage={ogImage} title={title} description={description} keywords={keywords}>
  {isPremium ? (

    <!-- PREMIUM PAGINA -->
    <div class="premium-page">

      <!-- Hero: video of eerste foto -->
      <div class="hero">
        {videoUrl ? (
          <>
            <video id="hero-video" src={videoUrl} class="hero-media" loop playsinline preload="metadata" />
            <button class="play-btn" id="play-btn" aria-label="Speel video af">
              <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </>
        ) : allPhotos[0] ? (
          <img src={allPhotos[0]} alt={`${restaurant!.name}`} class="hero-media" />
        ) : (
          <div class="hero-placeholder" />
        )}
        <div class="hero-overlay" />
        <div class="hero-content">
          <h1 class="hero-name">{restaurant!.name}</h1>
          <p class="hero-city">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            {restaurant!.city}{restaurant!.address && <span class="hero-address"> · {restaurant!.address}</span>}
          </p>
          <div class="hero-tags">
            {restaurant!.cuisine && <span class="hero-tag">{restaurant!.cuisine}</span>}
            {restaurant!.vibe && <span class="hero-tag">{restaurant!.vibe}</span>}
            {restaurant!.price_level && <span class="hero-tag">{priceLabel(restaurant!.price_level)}</span>}
            {restaurant!.weighted_score && (
              <span class="hero-tag score">★ {Number(restaurant!.weighted_score).toFixed(1)}</span>
            )}
          </div>
        </div>
      </div>

      <!-- Desktop twee-kolom layout -->
      <div class="page-body">

        <!-- Linker kolom: beschrijving + CTA -->
        <div class="col-info">

          {restaurant!.description && (
            <section class="section reveal">
              <h2 class="section-title">Over dit restaurant</h2>
              <p class="description">{restaurant!.description}</p>
            </section>
          )}

          <!-- CTA blok (desktop, direct onder beschrijving) -->
          <div class="cta-card reveal">
            <p class="cta-eyebrow">Meer zien?</p>
            <p class="cta-title">Bekijk video's, reviews<br/>en reserveer via Tastory</p>
            <a href={deepLinkUrl} class="btn-primary" id="open-app-btn">
              Open in Tastory
            </a>
            <div class="divider"><span>Nog geen Tastory?</span></div>
            <a href={appStoreUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Download Tastory — gratis
            </a>
            <p class="store-note">Beschikbaar op iOS · Binnenkort op Android</p>
          </div>

        </div>

        <!-- Rechter kolom: foto's + openingstijden -->
        <div class="col-media">
          {allPhotos.length > 0 && (
            <section class="section reveal">
              <h2 class="section-title">Foto's</h2>
              <div class="gallery">
                {allPhotos.map((src, i) => (
                  <div class="gallery-item">
                    <img src={src} alt={`${restaurant!.name} foto ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
                  </div>
                ))}
              </div>
            </section>
          )}

          {restaurant!.opening_hours && (
            <section class="section reveal">
              <h2 class="section-title">Openingstijden</h2>
              <p class="hours-text">{restaurant!.opening_hours}</p>
            </section>
          )}
        </div>

      </div>

      <!-- Mobiele sticky CTA balk -->
      <div class="mobile-cta" id="mobile-cta">
        <a href={deepLinkUrl} class="mobile-cta-btn" id="mobile-app-btn">
          Bekijk in Tastory
        </a>
        <a href={appStoreUrl} class="mobile-cta-download" target="_blank" rel="noopener noreferrer">
          Download
        </a>
      </div>

    </div>

  ) : (

    <!-- STANDAARD PAGINA (niet-premium) -->
    <div class="restaurant-page">
      <div class="content">
        <div class="card reveal">
          {restaurant ? (
            <>
              {allPhotos[0] && (
                <div class="photo-wrap">
                  <img src={allPhotos[0]} alt={restaurant.name} class="photo" />
                </div>
              )}
              <div class="info">
                <h1 class="name">{restaurant.name}</h1>
                <p class="city">{restaurant.city}</p>
                <div class="meta">
                  {restaurant.cuisine && <span class="tag">{restaurant.cuisine}</span>}
                  {restaurant.vibe && <span class="tag">{restaurant.vibe}</span>}
                  {restaurant.price_level && <span class="tag">{priceLabel(restaurant.price_level)}</span>}
                  {restaurant.weighted_score && (
                    <span class="tag score">★ {Number(restaurant.weighted_score).toFixed(1)}</span>
                  )}
                </div>
                {restaurant.description && (
                  <p class="description">{restaurant.description}</p>
                )}
                {restaurant.address && (
                  <p class="address">📍 {restaurant.address}</p>
                )}
              </div>
            </>
          ) : (
            <h1>Restaurant bekijken</h1>
          )}

          <a href={deepLinkUrl} class="btn-primary" id="open-app-btn">
            Open in Tastory
          </a>
          <div class="divider"><span>Heb je Tastory nog niet?</span></div>
          <a href={appStoreUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            Download Tastory
          </a>
          <p class="store-note">Beschikbaar op iOS · Binnenkort op Android</p>
        </div>
      </div>
    </div>

  )}
</BaseLayout>

<style>
  /* ── PREMIUM PAGE ─────────────────────────────────────── */

  .premium-page {
    background: var(--beige);
    min-height: 100vh;
    padding-bottom: 6rem; /* ruimte voor mobiele sticky balk */
  }

  /* Hero */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 480px;
    max-height: 700px;
    overflow: hidden;
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-placeholder {
    width: 100%;
    height: 100%;
    background: var(--brown);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.65) 100%);
    pointer-events: none;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2xl) var(--space-xl);
    color: #fff;
  }

.hero-name {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 0.5rem;
  }

  .hero-city {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-sm);
    opacity: 0.85;
    margin-bottom: var(--space-md);
  }

  .hero-address {
    opacity: 0.7;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .hero-tag {
    font-size: var(--text-xs);
    font-weight: 500;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    color: #fff;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .hero-tag.score {
    background: rgba(255, 142, 62, 0.7);
    border-color: transparent;
  }

  /* Play knop */
  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(8px);
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    z-index: 2;
  }

  .play-btn:hover {
    background: rgba(255,255,255,0.35);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .play-btn.hidden {
    display: none;
  }

  /* Twee-kolom body */
  .page-body {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .col-info {
    position: sticky;
    top: 2rem;
  }

  /* Sections */
  .section {
    margin-bottom: var(--space-2xl);
  }

  .section-title {
    font-family: var(--serif);
    font-size: var(--text-xl);
    color: var(--text);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(136, 101, 69, 0.15);
  }

  .description {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.8;
  }

  .hours-text {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.8;
    white-space: pre-line;
  }

  .address-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: var(--text-base);
    color: var(--orange);
    text-decoration: none;
    line-height: 1.6;
    transition: opacity 0.2s;
  }

  .address-link:hover { opacity: 0.75; }

  .address-link svg {
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  /* CTA kaart */
  .cta-card {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }

  .cta-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--orange);
    margin-bottom: var(--space-xs);
  }

  .cta-title {
    font-family: var(--serif);
    font-size: var(--text-xl);
    color: var(--text);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
  }

  /* Fotogalerij (rechter kolom) */
  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .gallery-item {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .gallery-item:first-child {
    grid-column: 1 / -1;
    aspect-ratio: 16/9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .gallery-item img:hover {
    transform: scale(1.04);
  }

  /* Mobiele sticky CTA */
  .mobile-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    background: #fff;
    border-top: 1px solid rgba(136, 101, 69, 0.12);
    box-shadow: 0 -4px 20px rgba(136, 101, 69, 0.1);
    gap: 0.75rem;
    z-index: 100;
    align-items: center;
  }

  .mobile-cta-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--orange);
    color: #fff;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s;
  }

  .mobile-cta-btn:hover { background: var(--brown); }

  .mobile-cta-download {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--beige);
    color: var(--text);
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.85rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(136, 101, 69, 0.2);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .mobile-cta-download:hover { background: rgba(136, 101, 69, 0.1); }

  /* ── RESPONSIVE ───────────────────────────────────────── */

  @media (max-width: 768px) {
    .hero {
      height: 65vh;
      max-height: 520px;
    }

    .hero-content {
      padding: var(--space-lg) var(--space-md);
    }

    .page-body {
      grid-template-columns: 1fr;
      padding: var(--space-lg) var(--space-md);
      gap: 0;
    }

    .col-info {
      position: static;
      order: 2;
    }

    .col-media {
      order: 1;
    }

    .gallery {
      grid-template-columns: 1fr 1fr;
      overflow-x: auto;
      display: flex;
      flex-wrap: nowrap;
      gap: 0.5rem;
      padding-bottom: 0.5rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .gallery-item {
      flex: 0 0 75vw;
      scroll-snap-align: start;
      aspect-ratio: 4/3;
    }

    .gallery-item:first-child {
      flex: 0 0 85vw;
      aspect-ratio: 4/3;
    }

    .mobile-cta {
      display: flex;
    }

    .cta-card {
      display: none;
    }

    .premium-page {
      padding-bottom: 5rem;
    }
  }

  /* ── STANDAARD PAGE ───────────────────────────────────── */

  .restaurant-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 6rem 1.5rem 4rem;
    background-color: var(--beige);
  }

  .content {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }

  .card {
    background: #ffffff;
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .photo-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    aspect-ratio: 4/3;
    max-height: 280px;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info { margin-bottom: 1.5rem; }

  .name {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
    font-family: var(--serif);
  }

  .city {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--brown);
    background: rgba(136, 101, 69, 0.1);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
  }

  .tag.score {
    color: var(--orange);
    background: rgba(255, 142, 62, 0.1);
    font-weight: 600;
  }

  .description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .address {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  /* ── GEDEELDE KNOPPEN ─────────────────────────────────── */

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--orange);
    color: #ffffff;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 1.25rem;
  }

  .btn-primary:hover {
    background: var(--brown);
    transform: translateY(-1px);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(136, 101, 69, 0.15);
  }

  .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--beige);
    color: var(--text);
    border: 1px solid rgba(136, 101, 69, 0.2);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .btn-secondary:hover {
    background: rgba(136, 101, 69, 0.1);
    transform: translateY(-1px);
  }

  .store-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.6;
  }
</style>

<script>
  // Deep link handler
  const appBtn = document.getElementById('open-app-btn');
  if (appBtn) {
    appBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const deepLink = appBtn.getAttribute('href');
      if (deepLink) window.location.href = deepLink;
    });
  }

  const mobileBtn = document.getElementById('mobile-app-btn');
  if (mobileBtn) {
    mobileBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const deepLink = mobileBtn.getAttribute('href');
      if (deepLink) window.location.href = deepLink;
    });
  }

  // Video play knop
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const playBtn = document.getElementById('play-btn');
  if (video && playBtn) {
    playBtn.addEventListener('click', () => {
      video.play();
      playBtn.classList.add('hidden');
    });
    video.addEventListener('pause', () => {
      playBtn.classList.remove('hidden');
    });
  }
</script>
