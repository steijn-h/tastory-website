---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import AppStoreBadges from '../components/AppStoreBadges.astro';
---

<BaseLayout
  title="Download de app — Tastory"
  description="Tastory komt in 2026! Download de app in de App Store of Google Play. Meld je nu aan als restaurant of als Foodie en wees er als eerste bij."
>
  <PageHero
    title="De app komt in <em>2026</em>"
    description="Tastory is bijna klaar om gelanceerd te worden. Binnenkort beschikbaar in de App Store en Google Play."
  />

  <section class="store-section">
    <div class="store-inner reveal">
      <div class="store-platforms">
        <div class="platform-card">
          <div class="platform-icon platform-icon--apple">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
          </div>
          <h3>iOS App Store</h3>
          <p>Beschikbaar voor iPhone en iPad. Vereist iOS 16 of hoger.</p>
          <div class="platform-badge-wrap">
            <AppStoreBadges theme="light" size="md" showLabel={false} />
          </div>
        </div>

        <div class="platform-divider">
          <span>en</span>
        </div>

        <div class="platform-card">
          <div class="platform-icon platform-icon--android">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3.18 23.76c.3.16.64.22.99.16l13.12-7.59L14 13l-10.82 10.76zM.88 1.56C.34 1.97 0 2.64 0 3.46v17.08c0 .82.34 1.49.88 1.9L1 22.55 12.44 11.1v-.2L1 .45.88 1.56zM22.15 10.28l-2.83-1.63L15.9 12l3.42 3.35 2.84-1.63c.81-.47.81-1.97-.01-2.44zM4.17.24L17.32 7.83 14 11.1 3.18.34C3.5.18 3.88.13 4.17.24z" />
            </svg>
          </div>
          <h3>Google Play</h3>
          <p>Beschikbaar voor Android. Vereist Android 9 of hoger.</p>
          <div class="platform-badge-wrap">
            <AppStoreBadges theme="light" size="md" showLabel={false} />
          </div>
        </div>
      </div>

      <div class="store-note">
        <div class="store-note-icon">🔔</div>
        <p>
          Meld je hieronder aan en ontvang een melding zodra Tastory beschikbaar is in de stores.
        </p>
      </div>
    </div>
  </section>

  <section class="signup-section">
    <div class="signup-grid">

      <div class="signup-card reveal">
        <div class="card-tag">Voor restaurants</div>
        <h2>Aanmelden als <em>Restaurant</em></h2>
        <p>
          Presenteer jouw restaurant via authentieke videocontent en bereik gasten die écht bij jou passen.
          Meld je nu aan en wij nemen contact met je op zodra we live gaan.
        </p>
        <form class="signup-form" id="restaurant-form">
          <input
            type="text"
            id="restaurant-name"
            placeholder="Naam restaurant"
            required
            aria-label="Naam restaurant"
          />
          <input
            type="email"
            id="restaurant-email"
            placeholder="E-mailadres"
            required
            aria-label="E-mailadres"
          />
          <button type="submit">Aanmelden als restaurant</button>
        </form>
        <div class="form-feedback" id="restaurant-feedback"></div>
        <div class="card-note">Geen spam. We nemen contact met je op bij de lancering.</div>
      </div>

      <div class="signup-card reveal">
        <div class="card-tag">Voor Foodies</div>
        <h2>Aanmelden als <em>Foodie</em></h2>
        <p>
          Ontdek restaurants die écht bij jou passen op basis van sfeer, keuken en stijl.
          Meld je aan en ontvang een melding zodra de app beschikbaar is.
        </p>
        <form class="signup-form" id="foodie-form">
          <input
            type="text"
            id="foodie-name"
            placeholder="Jouw naam"
            required
            aria-label="Jouw naam"
          />
          <input
            type="email"
            id="foodie-email"
            placeholder="E-mailadres"
            required
            aria-label="E-mailadres"
          />
          <button type="submit">Aanmelden als Foodie</button>
        </form>
        <div class="form-feedback" id="foodie-feedback"></div>
        <div class="card-note">Geen spam. Altijd opzegbaar. Binnenkort op iOS &amp; Android.</div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* App Store section */
  .store-section {
    padding: 4rem 3rem 0;
  }

  .store-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .store-platforms {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-xl);
    padding: 3rem;
    box-shadow: var(--shadow-md);
    margin-bottom: 1.5rem;
  }

  .platform-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .platform-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }

  .platform-icon svg {
    width: 32px;
    height: 32px;
  }

  .platform-icon--apple {
    background: #000;
    color: #fff;
  }

  .platform-icon--android {
    background: #01875f;
    color: #fff;
  }

  .platform-card h3 {
    font-family: var(--serif);
    font-size: 1.25rem;
    color: var(--text);
    font-weight: 600;
  }

  .platform-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 200px;
  }

  .platform-badge-wrap {
    margin-top: 0.5rem;
  }

  .platform-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
    opacity: 0.5;
    flex-shrink: 0;
  }

  .store-note {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 142, 62, 0.08);
    border: 1px solid rgba(255, 142, 62, 0.2);
    border-radius: var(--radius-md);
    padding: 1rem 1.5rem;
  }

  .store-note-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .store-note p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .store-section {
      padding: 3rem 1.5rem 0;
    }

    .store-platforms {
      flex-direction: column;
      padding: 2rem;
      gap: 2rem;
    }

    .platform-divider {
      transform: rotate(0deg);
    }

    .platform-card p {
      max-width: 100%;
    }
  }

  /* Sign-up section */
  .signup-section {
    padding: 5rem 3rem 7rem;
    max-width: 100%;
  }

  .signup-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .signup-card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    padding: 3rem;
    box-shadow: var(--shadow-md);
  }

  .card-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(255, 142, 62, 0.1);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .signup-card h2 {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .signup-card h2 em {
    color: var(--orange);
    font-style: normal;
  }

  .signup-card > p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .signup-form input {
    padding: 0.9rem 1.2rem;
    border: 1px solid rgba(136, 101, 69, 0.2);
    border-radius: var(--radius-md);
    background: var(--beige);
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .signup-form input:focus {
    border-color: var(--orange);
  }

  .signup-form input::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .signup-form button {
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
    margin-top: 0.25rem;
  }

  .signup-form button:hover {
    background: var(--brown);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(255, 142, 62, 0.3);
  }

  .form-feedback {
    font-size: 0.95rem;
    margin-top: 0.75rem;
    min-height: 1.4rem;
  }

  .form-feedback--success {
    color: #2e7d32;
  }

  .form-feedback--error {
    color: #c62828;
  }

  .card-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 0.75rem;
  }

  @media (max-width: 768px) {
    .signup-section {
      padding: 4rem 1.5rem 5rem;
    }

    .signup-grid {
      grid-template-columns: 1fr;
    }

    .signup-card {
      padding: 2rem;
    }
  }
</style>

<script>
  async function submitForm(
    formId: string,
    nameInputId: string,
    emailInputId: string,
    feedbackId: string,
    type: string,
  ) {
    const form = document.getElementById(formId) as HTMLFormElement;
    const nameInput = document.getElementById(nameInputId) as HTMLInputElement;
    const emailInput = document.getElementById(emailInputId) as HTMLInputElement;
    const feedback = document.getElementById(feedbackId) as HTMLDivElement;
    const submitBtn = form.querySelector('button') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = nameInput.value.trim();
      const email = emailInput.value.trim();
      if (!name || !email) return;

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent ?? 'Aanmelden';
      submitBtn.textContent = 'Verzenden...';

      try {
        const res = await fetch('https://formsubmit.co/ajax/Info@tastory.nl', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            name,
            email,
            message: `Nieuwe aanmelding via de download pagina als ${type}.`,
            _subject: `Nieuwe aanmelding als ${type} — Tastory`,
            _captcha: 'false',
            _template: 'table',
          }),
        });

        if (res.ok) {
          feedback.textContent = 'Bedankt voor je aanmelding! We nemen contact met je op bij de lancering.';
          feedback.className = 'form-feedback form-feedback--success';
          nameInput.value = '';
          emailInput.value = '';
        } else {
          throw new Error('Submit failed');
        }
      } catch {
        feedback.textContent = 'Er ging iets mis. Probeer het later opnieuw.';
        feedback.className = 'form-feedback form-feedback--error';
      }

      submitBtn.disabled = false;
      submitBtn.textContent = originalText;

      setTimeout(() => {
        feedback.textContent = '';
        feedback.className = 'form-feedback';
      }, 6000);
    });
  }

  submitForm('restaurant-form', 'restaurant-name', 'restaurant-email', 'restaurant-feedback', 'Restaurant');
  submitForm('foodie-form', 'foodie-name', 'foodie-email', 'foodie-feedback', 'Foodie');
</script>
