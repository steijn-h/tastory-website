export const prerender = false;
---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;

let story: { id: string; user_name: string; restaurant_name: string; restaurant_id: string; photo_url: string | null } | null = null;
try {
  const res = await fetch(
    `https://vyqpdtjpocndgdqylzeo.supabase.co/rest/v1/stories?id=eq.${id}&select=id,user_name,restaurant_name,restaurant_id,photo_url`,
    {
      headers: {
        apikey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ5cXBkdGpwb2NuZGdkcXlsemVvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MzgwNjM2MTksImV4cCI6MjA1MzYzOTYxOX0.y7HGiROl1FH6vYBWD2MlFWOqEj_x5UIBgMBm7NBXH5Q',
        'Content-Type': 'application/json',
      },
    }
  );
  const data = await res.json();
  story = data?.[0] ?? null;
} catch {
  story = null;
}

const title = story
  ? `Taste Story van ${story.user_name} bij ${story.restaurant_name} — Tastory`
  : 'Taste Story — Tastory';
const description = story
  ? `Bekijk de Taste Story van ${story.user_name} bij ${story.restaurant_name} op Tastory.`
  : 'Bekijk deze Taste Story op Tastory.';
const ogImage = story?.photo_url ?? 'https://tastory.nl/og-image.png';
const appStoreUrl = 'https://apps.apple.com/nl/app/tastory/id6744042066';
const deepLinkUrl = `tastory://story/${id}`;
---

<BaseLayout ogImage={ogImage} title={title} description={description}>
  <div class="story-page">
    {story?.photo_url && (
      <div class="hero-image">
        <img src={story.photo_url} alt={`Taste Story bij ${story.restaurant_name}`} />
        <div class="hero-overlay" />
      </div>
    )}

    <div class="content">
      <div class="card reveal">
        <div class="card-tag">Taste Story op Tastory</div>

        {story ? (
          <>
            <h1>{story.restaurant_name}</h1>
            <p class="user">Door {story.user_name}</p>
          </>
        ) : (
          <h1>Taste Story bekijken</h1>
        )}

        <p class="cta-text">
          Open deze Taste Story in de Tastory app om hem volledig te bekijken.
        </p>

        <a href={deepLinkUrl} class="btn-primary" id="open-app-btn">
          Open in Tastory
        </a>

        <div class="divider">
          <span>Tastory nog niet?</span>
        </div>

        <a href={appStoreUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download Tastory
        </a>

        <p class="store-note">Beschikbaar op iOS · Binnenkort op Android</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .story-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem 5rem;
    position: relative;
  }

  .hero-image {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(8px) brightness(0.4);
    transform: scale(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
    padding-top: 4rem;
  }

  .card {
    background: var(--white);
    border: 1px solid rgba(136, 101, 69, 0.1);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .card-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(255, 142, 62, 0.1);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .card h1 {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .user {
    color: var(--orange);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .cta-text {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--orange);
    color: var(--white);
    border: none;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
    width: 100%;
    margin-bottom: 1.25rem;
  }

  .btn-primary:hover {
    background: var(--brown);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(255, 142, 62, 0.3);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(136, 101, 69, 0.15);
  }

  .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--beige);
    color: var(--text);
    border: 1px solid rgba(136, 101, 69, 0.2);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .btn-secondary:hover {
    background: rgba(136, 101, 69, 0.1);
    transform: translateY(-1px);
  }

  .store-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.6;
  }
</style>

<script>
  const appBtn = document.getElementById('open-app-btn');
  if (appBtn) {
    appBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const deepLink = appBtn.getAttribute('href');
      if (!deepLink) return;
      window.location.href = deepLink;
    });
  }
</script>
