---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Download Tastory — App Store"
  description="De Tastory app is nu live! Download hem gratis in de App Store."
>
  <section class="redirect-section">
    <div class="redirect-inner">
      <p class="redirect-text">Je wordt doorgestuurd naar de App Store…</p>
      <a
        href="https://apps.apple.com/nl/app/tastory/id6762256086"
        class="btn-primary"
        rel="noopener noreferrer"
      >
        Download de app
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  window.location.replace('https://apps.apple.com/nl/app/tastory/id6762256086');
</script>

<style>
  .redirect-section {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .redirect-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .redirect-text {
    font-size: 1.2rem;
    color: var(--text-muted);
  }
</style>
