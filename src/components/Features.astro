---
import Icon from './Icon.astro';

interface Props {
  features: { icon: string; title: string; description: string }[];
}

const { features } = Astro.props;
---

<div class="features-wrapper">
  <section>
    <div class="reveal">
      <div class="section-tag">Onze focus</div>
      <div class="section-title">Wordt geïnspireerd en <em>inspireer</em> anderen!</div>
      <div class="section-desc">
        Tastory creëert waarde voor zowel restaurantbezoekers als restaurants. Bezoekers worden
        geholpen in het maken van een juiste keuze en restaurants worden ondersteund in het versterken
        van hun bereik en conversie.
      </div>
    </div>
    <div class="features-list">
      {
        features.map((feature) => (
          <div class="feature-item reveal">
            <div class="feature-icon">
              <Icon name={feature.icon} size={24} />
            </div>
            <div class="feature-body">
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</div>

<style>
  .features-wrapper {
    background: #ffffff;
  }

  section {
    background: transparent;
  }

  section :global(.section-desc) {
    max-width: none;
  }

  .features-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 4rem;
    margin-top: 4rem;
  }

  .feature-item {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }

  .feature-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: rgba(255, 142, 62, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--orange);
    margin-top: 2px;
  }

  .feature-body h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .feature-body p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .features-list {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
