---
import Icon from './Icon.astro';

interface Props {
  features: { icon: string; title: string; description: string }[];
}

const { features } = Astro.props;
---

<section>
  <div class="reveal">
    <div class="section-tag">Onze focus</div>
    <div class="section-title">Wordt geïnspireerd en <em>inspireer</em> anderen!</div>
    <div class="section-desc">
      Tastory creëert waarde voor zowel restaurantbezoekers als restaurants. Bezoekers worden
      geholpen in het maken van een juiste keuze en restaurants worden ondersteund in het versterken
      van hun bereik en conversie.
    </div>
  </div>
  <div class="features-grid">
    {
      features.map((feature) => (
        <div class="feature-card reveal">
          <div class="feature-bg-icon">
            <Icon name={feature.icon} size={120} />
          </div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    background: #ffffff;
    padding-top: 4rem;
  }

  section :global(.section-desc) {
    max-width: none;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }

  .feature-card {
    background: #f9f6f2;
    border: 1px solid rgba(136, 101, 69, 0.15);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--orange), rgba(255, 142, 62, 0.3));
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 142, 62, 0.35);
    box-shadow: 0 12px 40px rgba(58, 46, 34, 0.1);
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  .feature-bg-icon {
    position: absolute;
    bottom: -10px;
    right: -10px;
    opacity: 0.14;
    pointer-events: none;
    color: var(--orange);
  }

  .feature-card h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 0.75rem;
    position: relative;
  }

  .feature-card p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-muted);
    position: relative;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
