---
import Icon from './Icon.astro';
---

<section id="oplossingen">
  <div class="reveal">
    <div class="section-tag">Probleem & Oplossing</div>
    <div class="section-title">
      Betere zichtbaarheid voor <em>restaurants.</em><br />Betere keuzes door <em>gasten.</em>
    </div>
  </div>
  <div class="ps-grid">
    <div class="problem-grid">
      <div class="problem-card problem reveal-left">
        <div class="problem-bg-icon"><Icon name="alert-circle" size={120} /></div>
        <h3>Het probleem</h3>
        <p>
          Door <strong>verouderde foto's</strong>, <strong>onbetrouwbare reviews</strong> en <strong
            >onoverzichtelijke platforms</strong
          > krijgen gebruikers vaak geen realistisch beeld van restaurants. Dit maakt het lastig om het
          juiste restaurant te kiezen en zorgt er tegelijkertijd voor dat restaurants gasten <strong
            >mislopen</strong
          >.
        </p>
      </div>
      <div class="problem-card solution reveal-left">
        <div class="problem-bg-icon"><Icon name="sparkles" size={120} /></div>
        <h3>Tastory biedt de oplossing</h3>
        <p>
          Via Tastory kunnen restaurants zich <span class="hl">beter en eerlijker presenteren</span
          >, terwijl gasten snel en eenvoudig restaurants ontdekken die écht bij hen passen.
          Kwalitatieve restaurantprofielen laat zien waar een restaurant echt voor staat — <span
            class="hl">authentiek, representatief en inspirerend.</span
          >
        </p>
      </div>
    </div>
    <div class="ps-phone reveal-right">
      <div class="phone-glow"></div>
      <div class="phone-wrapper">
        <!-- Physical buttons positioned relative to phone-wrapper -->
        <div class="phone-btn btn-action"></div>
        <div class="phone-btn btn-vol-up"></div>
        <div class="phone-btn btn-vol-down"></div>
        <div class="phone-btn btn-power"></div>

        <div class="phone-mockup">
          <div class="phone-screen">
            <!-- Dynamic Island -->
            <div class="dynamic-island"></div>
            <img
              src="/homepage-long-screenshot.png"
              alt="Tastory app screenshot"
              class="phone-screenshot"
              width="1170"
              height="4944"
              loading="lazy"
            />
          </div>
        </div>

        <div class="float-card float-card-1">
          <div class="fc-label">Reviews met hoge<br />betrouwbaarheid</div>
        </div>
        <div class="float-card float-card-2">
          <div class="fc-label">Jouw verhaal</div>
        </div>
        <div class="float-card float-card-3">
          <div class="fc-label">Actuele content</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    scroll-margin-top: 80px;
  }

  .ps-grid {
    display: grid;
    grid-template-columns: 1fr 430px;
    gap: 4rem;
    margin-top: 3.5rem;
    align-items: center;
  }

  .problem-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .problem-card {
    padding: 2.5rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }

  .problem-bg-icon {
    position: absolute;
    bottom: 10px;
    right: 10px;
    opacity: 0.1;
    pointer-events: none;
  }

  .problem-card.problem .problem-bg-icon {
    color: var(--brown);
  }

  .problem-card.solution .problem-bg-icon {
    color: var(--orange);
  }

  .problem-card.problem {
    background: rgba(136, 101, 69, 0.08);
    border: 1px solid rgba(136, 101, 69, 0.22);
    box-shadow: 0 4px 24px rgba(136, 101, 69, 0.07);
  }

  .problem-card.solution {
    background: rgba(255, 142, 62, 0.08);
    border: 1px solid rgba(255, 142, 62, 0.25);
    box-shadow: 0 4px 24px rgba(255, 142, 62, 0.08);
  }

  .problem-card h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 1.2rem;
  }

  .problem-card p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .problem-card .hl {
    color: var(--text);
    font-weight: 500;
  }

  .problem-card.problem strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ── Phone area ── */
  .ps-phone {
    display: flex;
    justify-content: flex-start;
    position: relative;
  }

  .phone-glow {
    position: absolute;
    width: 350px;
    height: 350px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(255, 142, 62, 0.28) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .phone-wrapper {
    position: relative;
    z-index: 1;
    /* Extra padding on left so buttons don't get clipped */
    padding-left: 6px;
  }

  /* ── iPhone 17 Pro Max frame ── */
  .phone-mockup {
    width: 280px;
    height: 600px;
    /* Orange titanium gradient */
    background: linear-gradient(
      160deg,
      #de8d45 0%,
      #c97332 40%,
      #c06c28 70%,
      #b86024 100%
    );
    border-radius: 46px;
    position: relative;
    overflow: hidden;
    /* Titanium chamfer highlights */
    box-shadow:
      /* Outer depth */
      0 28px 70px rgba(0, 0, 0, 0.32),
      0 8px 24px rgba(0, 0, 0, 0.18),
      /* Frame edge highlight (top-left light catch) */
      inset 2px 2px 0 rgba(255, 210, 150, 0.35),
      /* Frame edge shadow (bottom-right) */
      inset -1px -1px 0 rgba(80, 30, 0, 0.4),
      /* Outer rim */
      0 0 0 1px rgba(180, 90, 20, 0.6);
    --screenshot-scroll: -47%;
  }

  /* ── Screen inset ── */
  .phone-screen {
    position: absolute;
    inset: 9px;
    border-radius: 38px;
    overflow: hidden;
    background: #000;
  }

  /* ── Dynamic Island ── */
  .dynamic-island {
    position: absolute;
    top: 13px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 30px;
    background: #000;
    border-radius: 20px;
    z-index: 10;
    /* Subtle pill inner shadow for depth */
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.8);
  }

  /* ── Scrolling screenshot ── */
  .phone-screenshot {
    width: 100%;
    height: auto;
    display: block;
    animation: scroll-app 12s ease-in-out 1s infinite alternate;
  }

  @keyframes scroll-app {
    0%,
    15% {
      transform: translateY(0);
    }
    85%,
    100% {
      transform: translateY(var(--screenshot-scroll));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-screenshot {
      animation: none;
    }
  }

  /* ── Physical buttons (positioned relative to .phone-wrapper) ── */
  .phone-btn {
    position: absolute;
    /* Slightly darker orange, same hue as frame */
    background: linear-gradient(to right, #a85a1c, #b86524);
    box-shadow:
      -1px 0 4px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 200, 120, 0.25);
    z-index: 2;
  }

  /* Action button — left side, near top */
  .btn-action {
    left: 2px; /* phone-wrapper has padding-left: 6px, so mockup left edge is at 6px */
    top: 108px;
    width: 4px;
    height: 30px;
    border-radius: 2px 0 0 2px;
  }

  /* Volume up — left side */
  .btn-vol-up {
    left: 2px;
    top: 160px;
    width: 4px;
    height: 56px;
    border-radius: 2px 0 0 2px;
  }

  /* Volume down — left side */
  .btn-vol-down {
    left: 2px;
    top: 228px;
    width: 4px;
    height: 56px;
    border-radius: 2px 0 0 2px;
  }

  /* Power button — right side */
  .btn-power {
    left: calc(6px + 280px); /* padding-left + phone width */
    top: 175px;
    width: 4px;
    height: 78px;
    border-radius: 0 2px 2px 0;
    background: linear-gradient(to left, #a85a1c, #b86524);
    box-shadow:
      1px 0 4px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 200, 120, 0.25);
  }

  /* ── Float cards ── */
  .float-card {
    position: absolute;
    background: rgba(255, 252, 248, 0.95);
    backdrop-filter: blur(24px);
    border: 1.5px solid rgba(255, 142, 62, 0.35);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.75rem;
    animation: float 6s ease-in-out infinite;
    white-space: nowrap;
    box-shadow:
      0 4px 12px rgba(58, 46, 34, 0.08),
      0 12px 40px rgba(58, 46, 34, 0.1),
      0 0 0 1px rgba(255, 142, 62, 0.08);
  }

  .float-card-1 {
    top: 22%;
    right: -135px;
    animation-delay: 0s;
  }

  .float-card-2 {
    bottom: 16%;
    right: -120px;
    animation-delay: 2s;
  }

  .float-card-3 {
    top: 52%;
    right: -130px;
    animation-delay: 4s;
  }

  .fc-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text);
    font-weight: 500;
  }

  @media (max-width: 1200px) {
    .float-card-1 {
      right: -80px;
    }
    .float-card-2 {
      right: -70px;
    }
    .float-card-3 {
      right: -75px;
    }
  }

  @media (max-width: 1024px) {
    .ps-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .ps-phone {
      order: -1;
      justify-content: center;
    }

    .phone-wrapper {
      padding-left: 6px;
    }

    .phone-mockup {
      width: 240px;
      height: 514px;
      border-radius: 40px;
      --screenshot-scroll: -47%;
    }

    .phone-screen {
      inset: 8px;
      border-radius: 33px;
    }

    .dynamic-island {
      top: 11px;
      width: 82px;
      height: 26px;
    }

    .btn-action {
      top: 92px;
      height: 26px;
    }
    .btn-vol-up {
      top: 137px;
      height: 48px;
    }
    .btn-vol-down {
      top: 196px;
      height: 48px;
    }
    .btn-power {
      left: calc(6px + 240px);
      top: 150px;
      height: 67px;
    }

    .float-card-1 {
      right: -60px;
    }
    .float-card-2 {
      right: -55px;
    }
    .float-card-3 {
      right: -55px;
    }

    .fc-label {
      font-size: 0.65rem;
    }
  }

  @media (max-width: 640px) {
    .phone-mockup {
      width: 200px;
      height: 428px;
      border-radius: 36px;
      --screenshot-scroll: -47%;
    }

    .phone-screen {
      inset: 7px;
      border-radius: 30px;
    }

    .dynamic-island {
      top: 9px;
      width: 68px;
      height: 22px;
    }

    .btn-action {
      top: 77px;
      height: 22px;
      width: 3px;
    }
    .btn-vol-up {
      top: 114px;
      height: 40px;
      width: 3px;
    }
    .btn-vol-down {
      top: 163px;
      height: 40px;
      width: 3px;
    }
    .btn-power {
      left: calc(6px + 200px);
      top: 125px;
      height: 56px;
      width: 3px;
    }

    .float-card {
      padding: 0.3rem 0.55rem;
    }

    .float-card-1 {
      right: -80px;
    }
    .float-card-2 {
      right: -70px;
    }
    .float-card-3 {
      right: -75px;
    }

    .fc-label {
      font-size: 0.55rem;
    }
  }

  @media (max-width: 390px) {
    .phone-mockup {
      width: 190px;
      height: 405px;
      border-radius: 34px;
    }

    .phone-screen {
      inset: 7px;
      border-radius: 28px;
    }

    .dynamic-island {
      width: 64px;
      height: 20px;
    }

    .btn-action { top: 73px; }
    .btn-vol-up { top: 108px; }
    .btn-vol-down { top: 155px; }
    .btn-power {
      left: calc(6px + 190px);
      top: 118px;
    }

    .float-card-1 { right: -80px; }
    .float-card-2 { right: -70px; }
    .float-card-3 { right: -75px; }
  }

  @media (max-width: 360px) {
    .phone-mockup {
      width: 175px;
      height: 375px;
      border-radius: 32px;
    }

    .btn-power { left: calc(6px + 175px); }

    .float-card-1 { right: -65px; }
    .float-card-2 { right: -55px; }
    .float-card-3 { right: -60px; }
  }
</style>
