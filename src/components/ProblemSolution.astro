---
import Icon from './Icon.astro';
---

<section id="oplossingen">
  <div class="reveal">
    <div class="section-tag">Probleem & Oplossing</div>
    <div class="section-title">
      Betere zichtbaarheid voor <em>restaurants.</em><br />Betere keuzes door <em>gasten.</em>
    </div>
  </div>
  <div class="ps-grid">
    <div class="problem-grid">
      <div class="problem-card problem reveal-left">
        <div class="problem-bg-icon"><Icon name="alert-circle" size={120} /></div>
        <h3>Het probleem</h3>
        <p>
          Door <strong>verouderde foto's</strong>, <strong>onbetrouwbare reviews</strong> en <strong
            >onoverzichtelijke platforms</strong
          > krijgen gebruikers vaak geen realistisch beeld van restaurants. Dit maakt het lastig om het
          juiste restaurant te kiezen en zorgt er tegelijkertijd voor dat restaurants gasten <strong
            >mislopen</strong
          >.
        </p>
      </div>
      <div class="problem-card solution reveal-left">
        <div class="problem-bg-icon"><Icon name="sparkles" size={120} /></div>
        <h3>Tastory biedt de oplossing</h3>
        <p>
          Via Tastory kunnen restaurants zich <span class="hl">beter en eerlijker presenteren</span
          >, terwijl gasten snel en eenvoudig restaurants ontdekken die écht bij hen passen.
          Kwalitatieve restaurantprofielen laat zien waar een restaurant echt voor staat — <span
            class="hl">authentiek, representatief en inspirerend.</span
          >
        </p>
      </div>
    </div>
    <div class="ps-phone reveal-right">
      <div class="phone-glow"></div>
      <div class="phone-wrapper">
        <!-- Screenshot sits behind the SVG frame -->
        <div class="phone-screen">
          <img
            src="/homepage-long-screenshot.png"
            alt="Tastory app screenshot"
            class="phone-screenshot"
            width="1170"
            height="4944"
            loading="lazy"
          />
          <div class="screen-glare"></div>
        </div>

        <!-- SVG iPhone 17 Pro Max frame (renders on top) -->
        <svg
          class="phone-frame-svg"
          viewBox="0 0 290 600"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <defs>
            <!-- Orange titanium frame gradient -->
            <linearGradient id="frame-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#E8954E" />
              <stop offset="25%" stop-color="#D4803A" />
              <stop offset="60%" stop-color="#C07030" />
              <stop offset="100%" stop-color="#A85E20" />
            </linearGradient>
            <!-- Button gradient left -->
            <linearGradient id="btn-left" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#8A4810" />
              <stop offset="100%" stop-color="#C06828" />
            </linearGradient>
            <!-- Button gradient right -->
            <linearGradient id="btn-right" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#C06828" />
              <stop offset="100%" stop-color="#8A4810" />
            </linearGradient>
            <!-- Top chamfer highlight -->
            <linearGradient id="top-hi" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgba(255,220,160,0.65)" />
              <stop offset="100%" stop-color="rgba(255,220,160,0)" />
            </linearGradient>
            <!-- Left chamfer highlight -->
            <linearGradient id="left-hi" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(255,210,140,0.5)" />
              <stop offset="100%" stop-color="rgba(255,210,140,0)" />
            </linearGradient>
            <!-- Right chamfer shadow -->
            <linearGradient id="right-sh" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(60,20,0,0)" />
              <stop offset="100%" stop-color="rgba(60,20,0,0.45)" />
            </linearGradient>
            <!-- Bottom chamfer shadow -->
            <linearGradient id="bot-sh" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgba(60,20,0,0)" />
              <stop offset="100%" stop-color="rgba(60,20,0,0.4)" />
            </linearGradient>
          </defs>

          <!--
            Frame: outer rounded rect (5,0)→(285,600) r=46
            Screen cutout: inner rounded rect (17,12)→(273,588) r=34
            even-odd fill rule creates the transparent screen hole
          -->
          <path
            fill-rule="evenodd"
            fill="url(#frame-grad)"
            d="
              M 51,0 H 239 A 46,46 0 0,1 285,46 V 554 A 46,46 0 0,1 239,600 H 51 A 46,46 0 0,1 5,554 V 46 A 46,46 0 0,1 51,0 Z
              M 51,12 A 34,34 0 0,0 17,46 V 554 A 34,34 0 0,0 51,588 H 239 A 34,34 0 0,0 273,554 V 46 A 34,34 0 0,0 239,12 Z
            "
          />

          <!-- Top chamfer highlight strip -->
          <path
            fill="url(#top-hi)"
            d="M 51,0 H 239 A 46,46 0 0,1 285,46 V 50 A 46,46 0 0,0 239,4 H 51 A 46,46 0 0,0 5,50 V 46 A 46,46 0 0,1 51,0 Z"
          />
          <!-- Left chamfer highlight -->
          <rect x="5" y="46" width="5" height="508" fill="url(#left-hi)" />
          <!-- Right chamfer shadow -->
          <rect x="280" y="46" width="5" height="508" fill="url(#right-sh)" />
          <!-- Bottom chamfer shadow -->
          <path
            fill="url(#bot-sh)"
            d="M 51,600 H 239 A 46,46 0 0,0 285,554 V 550 A 46,46 0 0,1 239,596 H 51 A 46,46 0 0,1 5,550 V 554 A 46,46 0 0,0 51,600 Z"
          />

          <!-- Outer rim line (subtle edge definition) -->
          <path
            fill="none"
            stroke="rgba(255,180,80,0.18)"
            stroke-width="1"
            d="M 51,0.5 H 239 A 45.5,45.5 0 0,1 284.5,46 V 554 A 45.5,45.5 0 0,1 239,599.5 H 51 A 45.5,45.5 0 0,1 5.5,554 V 46 A 45.5,45.5 0 0,1 51,0.5 Z"
          />
          <!-- Inner screen edge (where frame meets glass) -->
          <path
            fill="none"
            stroke="rgba(0,0,0,0.55)"
            stroke-width="1.5"
            d="M 51,12 A 34,34 0 0,0 17,46 V 554 A 34,34 0 0,0 51,588 H 239 A 34,34 0 0,0 273,554 V 46 A 34,34 0 0,0 239,12 Z"
          />

          <!-- Dynamic Island pill -->
          <rect x="97" y="20" width="96" height="30" rx="15" ry="15" fill="#000" />
          <!-- DI inner subtle highlight -->
          <rect
            x="97"
            y="20"
            width="96"
            height="30"
            rx="15"
            ry="15"
            fill="none"
            stroke="rgba(255,255,255,0.07)"
            stroke-width="1"
          />

          <!-- ── Physical buttons ── -->
          <!-- Action button (left, top) -->
          <rect x="1" y="112" width="6" height="30" rx="3" fill="url(#btn-left)" />
          <rect x="1" y="112" width="6" height="30" rx="3" fill="none" stroke="rgba(255,190,100,0.2)" stroke-width="0.5" />

          <!-- Volume up (left) -->
          <rect x="1" y="164" width="6" height="55" rx="3" fill="url(#btn-left)" />
          <rect x="1" y="164" width="6" height="55" rx="3" fill="none" stroke="rgba(255,190,100,0.2)" stroke-width="0.5" />

          <!-- Volume down (left) -->
          <rect x="1" y="231" width="6" height="55" rx="3" fill="url(#btn-left)" />
          <rect x="1" y="231" width="6" height="55" rx="3" fill="none" stroke="rgba(255,190,100,0.2)" stroke-width="0.5" />

          <!-- Power / side button (right) -->
          <rect x="283" y="180" width="6" height="76" rx="3" fill="url(#btn-right)" />
          <rect x="283" y="180" width="6" height="76" rx="3" fill="none" stroke="rgba(255,190,100,0.2)" stroke-width="0.5" />
        </svg>

        <div class="float-card float-card-1">
          <div class="fc-label">Reviews met hoge<br />betrouwbaarheid</div>
        </div>
        <div class="float-card float-card-2">
          <div class="fc-label">Jouw verhaal</div>
        </div>
        <div class="float-card float-card-3">
          <div class="fc-label">Actuele content</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    scroll-margin-top: 80px;
  }

  .ps-grid {
    display: grid;
    grid-template-columns: 1fr 430px;
    gap: 4rem;
    margin-top: 3.5rem;
    align-items: center;
  }

  .problem-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .problem-card {
    padding: 2.5rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }

  .problem-bg-icon {
    position: absolute;
    bottom: 10px;
    right: 10px;
    opacity: 0.1;
    pointer-events: none;
  }

  .problem-card.problem .problem-bg-icon { color: var(--brown); }
  .problem-card.solution .problem-bg-icon { color: var(--orange); }

  .problem-card.problem {
    background: rgba(136, 101, 69, 0.08);
    border: 1px solid rgba(136, 101, 69, 0.22);
    box-shadow: 0 4px 24px rgba(136, 101, 69, 0.07);
  }

  .problem-card.solution {
    background: rgba(255, 142, 62, 0.08);
    border: 1px solid rgba(255, 142, 62, 0.25);
    box-shadow: 0 4px 24px rgba(255, 142, 62, 0.08);
  }

  .problem-card h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 1.2rem;
  }

  .problem-card p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .problem-card .hl { color: var(--text); font-weight: 500; }
  .problem-card.problem strong { color: var(--text); font-weight: 600; }

  /* ── Phone section ── */
  .ps-phone {
    display: flex;
    justify-content: flex-start;
    position: relative;
  }

  .phone-glow {
    position: absolute;
    width: 350px;
    height: 350px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(255, 142, 62, 0.28) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .phone-wrapper {
    position: relative;
    z-index: 1;
  }

  /* ── Phone outer: contains screen + SVG frame ── */

  /*
    SVG viewBox: 0 0 290 600
    Screen area in SVG coords: x=17 y=12 w=256 h=576 rx=34
    phone-screen positioned to match exactly
  */
  .phone-screen {
    position: absolute;
    left: 17px;
    top: 12px;
    width: 256px;
    height: 576px;
    border-radius: 34px;
    overflow: hidden;
    background: #000;
  }

  .phone-screenshot {
    width: 100%;
    height: auto;
    display: block;
    animation: scroll-app 12s ease-in-out 1.5s infinite alternate;
  }

  /* translateY % is relative to element's own height → scale-independent */
  @keyframes scroll-app {
    0%, 15%  { transform: translateY(0); }
    85%, 100% { transform: translateY(-47%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-screenshot { animation: none; }
  }

  /* Very subtle screen glass glare */
  .screen-glare {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.01) 40%,
      transparent 60%
    );
    pointer-events: none;
    border-radius: inherit;
  }

  /* SVG frame sits on top, pointer-events none so screenshot is accessible */
  .phone-frame-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 290px;
    height: 600px;
    pointer-events: none;
    /* Drop shadow follows the actual SVG shape (not bounding box) */
    filter:
      drop-shadow(0 28px 60px rgba(0, 0, 0, 0.38))
      drop-shadow(0 8px 20px rgba(150, 70, 10, 0.28))
      drop-shadow(0 2px 6px rgba(0, 0, 0, 0.25));
  }

  /* ── Float cards ── */
  .float-card {
    position: absolute;
    background: rgba(255, 252, 248, 0.95);
    backdrop-filter: blur(24px);
    border: 1.5px solid rgba(255, 142, 62, 0.35);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.75rem;
    animation: float 6s ease-in-out infinite;
    white-space: nowrap;
    box-shadow:
      0 4px 12px rgba(58, 46, 34, 0.08),
      0 12px 40px rgba(58, 46, 34, 0.1),
      0 0 0 1px rgba(255, 142, 62, 0.08);
  }

  .float-card-1 { top: 22%; right: -135px; animation-delay: 0s; }
  .float-card-2 { bottom: 16%; right: -120px; animation-delay: 2s; }
  .float-card-3 { top: 52%; right: -130px; animation-delay: 4s; }

  .fc-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text);
    font-weight: 500;
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .float-card-1 { right: -80px; }
    .float-card-2 { right: -70px; }
    .float-card-3 { right: -75px; }
  }

  @media (max-width: 1024px) {
    .ps-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .ps-phone {
      order: -1;
      justify-content: center;
    }

    /* Scale: 248/290 ≈ 0.855 */
    .phone-screen {
      left: 14px; top: 10px;
      width: 219px; height: 492px;
      border-radius: 29px;
    }
    .phone-frame-svg { width: 248px; height: 513px; }

    .float-card-1 { right: -60px; }
    .float-card-2 { right: -55px; }
    .float-card-3 { right: -55px; }
    .fc-label { font-size: 0.65rem; }
  }

  @media (max-width: 640px) {
    /* Scale: 200/290 ≈ 0.690 */
    .phone-screen {
      left: 12px; top: 8px;
      width: 177px; height: 397px;
      border-radius: 24px;
    }
    .phone-frame-svg { width: 200px; height: 414px; }

    .float-card { padding: 0.3rem 0.55rem; }
    .float-card-1 { right: -80px; }
    .float-card-2 { right: -70px; }
    .float-card-3 { right: -75px; }
    .fc-label { font-size: 0.55rem; }
  }

  @media (max-width: 390px) {
    /* Scale: 190/290 ≈ 0.655 */
    .phone-screen {
      left: 11px; top: 8px;
      width: 168px; height: 378px;
      border-radius: 22px;
    }
    .phone-frame-svg { width: 190px; height: 393px; }

    .float-card-1 { right: -80px; }
    .float-card-2 { right: -70px; }
    .float-card-3 { right: -75px; }
  }

  @media (max-width: 360px) {
    /* Scale: 175/290 ≈ 0.603 */
    .phone-screen {
      left: 10px; top: 7px;
      width: 155px; height: 348px;
      border-radius: 21px;
    }
    .phone-frame-svg { width: 175px; height: 362px; }

    .float-card-1 { right: -65px; }
    .float-card-2 { right: -55px; }
    .float-card-3 { right: -60px; }
  }
</style>
