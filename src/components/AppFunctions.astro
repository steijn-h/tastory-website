---
import Icon from './Icon.astro';

interface AppFunction {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  functions: AppFunction[];
}

const { functions } = Astro.props;
---

<div class="app-functions-wrapper">
  <section>
    <div class="reveal">
      <div class="section-tag">De app</div>
      <div class="section-title">Wat kan je met de <em>Tastory-app</em>?</div>
      <div class="section-desc">
        Van ontdekken tot delen Tastory begeleidt je bij elke stap van jouw restaurantbeleving.
        Dit zijn de kernfuncties van onze app.
      </div>
    </div>

    <div class="functions-grid">
      {
        functions.map((fn, i) => (
          <div class="fn-card reveal">
            <div class="fn-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="fn-icon">
              <Icon name={fn.icon} size={22} />
            </div>
            <h3>{fn.title}</h3>
            <p>{fn.description}</p>
          </div>
        ))
      }
    </div>
  </section>
</div>

<style>
  .app-functions-wrapper {
    background: var(--white);
  }

  .functions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }

  .fn-card {
    position: relative;
    background: var(--beige);
    border: 1px solid rgba(136, 101, 69, 0.12);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem 1.75rem;
    overflow: hidden;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .fn-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .fn-number {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: rgba(136, 101, 69, 0.12);
    line-height: 1;
    user-select: none;
  }

  .fn-icon {
    width: 44px;
    height: 44px;
    background: rgba(255, 142, 62, 0.1);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--orange);
    margin-bottom: 1.1rem;
  }

  .fn-card h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .fn-card p {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .functions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .functions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
