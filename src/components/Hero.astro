
---
---
<section class="hero" id="hero">
  <video class="hero-video" autoplay muted loop playsinline>
    <source src="/Achtergrond video 2.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        In 2026 live
      </div>
      <h1>Find it. Taste it.<br /><em>Share it.</em></h1>
      <p class="hero-desc">
        De ultieme smaakvolle verbinding tussen gast en restaurant. Via Tastory kunnen restaurants
        zich beter en eerlijker presenteren, terwijl gasten snel en eenvoudig restaurants
        ontdekken die écht bij hen passen.
      </p>
      <div class="hero-actions">
        <a href={`${import.meta.env.BASE_URL}aanmelden/restaurant`} class="btn-primary">Meld je aan als restaurant</a>
        <a href={`${import.meta.env.BASE_URL}aanmelden/foodie`} class="btn-secondary">Meld je aan als Foodie</a>
      </div>
    </div>
  </div>
</section>
<script>
  const video = document.querySelector('.hero-video') as HTMLVideoElement;
  if (video) video.playbackRate = 0.8;

  // Restart video when page is restored from bfcache (back/forward navigation)
  window.addEventListener('pageshow', (e) => {
    if (e.persisted && video) {
      video.play();
    }
  });
</script>
<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    min-height: 100vh;
    overflow: hidden;
    padding: 9rem 3rem 5rem;
    max-width: none;
    margin: 0;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      160deg,
      rgba(46, 35, 24, 0.82) 0%,
      rgba(61, 47, 31, 0.75) 50%,
      rgba(46, 35, 24, 0.82) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    text-align: center;
  }
  .hero-text {
    animation: fadeUp 1s 0.2s ease both;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 142, 62, 0.12);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 142, 62, 0.25);
    border-radius: 100px;
    padding: 0.5rem 1.4rem 0.5rem 0.8rem;
    margin-bottom: 2rem;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orange-light);
    font-weight: 500;
  }
  .hero-badge-dot {
    width: 8px;
    height: 8px;
    background: var(--orange);
    border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(255, 142, 62, 0.6);
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(3rem, 5vw, 5rem);
    line-height: 1.08;
    color: var(--white);
    font-weight: 700;
    margin-bottom: 1.8rem;
    text-shadow: 0 2px 30px rgba(58, 46, 34, 0.3);
  }
  .hero h1 em {
    color: var(--orange);
    font-style: normal;
  }
  .hero-desc {
    font-size: 1.15rem;
    line-height: 1.85;
    color: rgba(255, 252, 248, 0.78);
    max-width: 560px;
    margin-bottom: 2.8rem;
  }
  .hero-actions {
    display: flex;
    gap: 1.2rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 640px) {
    .hero {
      padding: 6rem 1.5rem 3rem;
    }

    .hero-actions :global(.btn-primary),
    .hero-actions :global(.btn-secondary) {
      font-size: 0.875rem;
      padding: 0.75rem 1.5rem;
    }
  }
</style>
