<style>
  footer {
    background: var(--brown-dark);
    padding: 4rem 3rem;
    color: rgba(245, 235, 221, 0.7);
    position: relative;
  }
  footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 142, 62, 0.3), transparent);
  }
  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
  }
  .footer-brand {
    font-family: var(--serif);
    font-size: var(--text-2xl);
    color: var(--beige);
    margin-bottom: 0.5rem;
  }
  .footer-brand-sub {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: rgba(245, 235, 221, 0.5);
  }
  .footer-cols {
    display: flex;
    gap: 3rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-col h4 {
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--beige);
    margin-bottom: 0.4rem;
    font-weight: 500;
  }
  .footer-col a {
    font-size: var(--text-sm);
    color: rgba(245, 235, 221, 0.55);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-col a:hover {
    color: var(--orange);
  }
  .footer-legal {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .footer-legal p {
    font-size: var(--text-xs);
    color: rgba(245, 235, 221, 0.35);
  }
  .footer-legal-link {
    font-size: var(--text-xs);
    color: rgba(245, 235, 221, 0.45);
    text-decoration: none;
    transition: color 0.3s;
    margin-top: 0.2rem;
  }
  .footer-legal-link:hover {
    color: var(--orange);
  }
  @media (max-width: 768px) {
    footer {
      padding: 3rem 1.5rem;
    }
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-cols {
      flex-wrap: wrap;
      gap: 2rem;
    }
    .footer-legal {
      text-align: left;
    }
  }
</style>
